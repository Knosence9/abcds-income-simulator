      { label: 'Start Here', icon: 'start', href: '/getting-started' },
      { label: 'Budget', icon: 'budget', href: '/budget' },
      { label: 'Simulator', icon: 'simulator', href: '/simulator' },
    ],
    lineItems: [
      { label: 'Pillars', icon: 'pillars', href: '/#pillars' },
      { label: 'Rules', icon: 'rules', href: '/#rules' },
      { label: 'Positions', icon: 'positions', href: '/#positions' },
      { label: 'Gears', icon: 'gears', href: '/#gears' },
      { label: 'Lifecycle', icon: 'lifecycle', href: '/#lifecycle' },
      { label: 'Cash Flow', icon: 'cashflow', href: '/#cashflow' },
      { label: 'Examples', icon: 'examples', href: '/#examples' },
    ],
  },
  'getting-started': {
    roundItems: [
      { label: 'Main Guide', icon: 'overview', href: '/' },
      { label: 'Start Here', icon: 'start', href: '/getting-started' },
      { label: 'Budget', icon: 'budget', href: '/budget' },
      { label: 'Simulator', icon: 'simulator', href: '/simulator' },
    ],
    lineItems: [
      { label: 'Platform Hub', icon: 'overview', href: '/getting-started#getting-started' },
      { label: 'Weekly Number', icon: 'weekly', href: '/budget#weekly-number' },
      { label: 'Contribution', icon: 'contribution', href: '/budget#contribution' },
      { label: 'Gears', icon: 'gears', href: '/#gears' },
      { label: 'Simulator', icon: 'simulator', href: '/simulator' },
    ],
  },
  budget: {
    roundItems: [
      { label: 'Main Guide', icon: 'overview', href: '/' },
      { label: 'Start Here', icon: 'start', href: '/getting-started' },
      { label: 'Budget', icon: 'budget', href: '/budget' },
      { label: 'Simulator', icon: 'simulator', href: '/simulator' },
    ],
    lineItems: [
      { label: 'Weekly Number', icon: 'weekly', href: '/budget#weekly-number' },
      { label: 'Contribution', icon: 'contribution', href: '/budget#contribution' },
      { label: 'Expenses', icon: 'expenses', href: '/budget#expenses' },
      { label: 'Budget Flow', icon: 'flow', href: '/budget#budget-flow' },
      { label: 'Using Guide', icon: 'examples', href: '/budget#using-guide' },
      { label: 'How It Fits', icon: 'lifecycle', href: '/budget#fits-main-guide' },
    ],
  },
  simulator: {
    roundItems: [
      { label: 'Main Guide', icon: 'overview', href: '/' },
      { label: 'Start Here', icon: 'start', href: '/getting-started' },
      { label: 'Budget', icon: 'budget', href: '/budget' },
      { label: 'Simulator', icon: 'simulator', href: '/simulator' },
    ],
    lineItems: [
      { label: 'Gears', icon: 'gears', href: '/#gears' },
      { label: 'Cash Flow', icon: 'cashflow', href: '/#cashflow' },
      { label: 'Examples', icon: 'examples', href: '/#examples' },
    ],
  },
  'demo-10': {
    roundItems: [
      { label: 'Main Guide', icon: 'overview', href: '/' },
      { label: 'Start Here', icon: 'start', href: '/getting-started' },
      { label: 'Budget', icon: 'budget', href: '/budget' },
      { label: 'Simulator', icon: 'simulator', href: '/simulator' },
      { label: 'Pillars', icon: 'pillars', href: '/#pillars' },
      { label: 'Rules', icon: 'rules', href: '/#rules' },
      { label: 'Positions', icon: 'positions', href: '/#positions' },
      { label: 'Gears', icon: 'gears', href: '/#gears' },
      { label: 'Lifecycle', icon: 'lifecycle', href: '/#lifecycle' },
      { label: 'Cash Flow', icon: 'cashflow', href: '/#cashflow' },
    ],
    lineItems: [
      { label: 'Examples', icon: 'examples', href: '/#examples' },
      { label: 'Weekly Number', icon: 'weekly', href: '/budget#weekly-number' },
    ],
  },
};

const {
  page = 'home',
  roundItems,
  lineItems,
  extraRoundItems = [],
  extraLineItems = [],
  activePath = Astro.url.pathname,
  label = 'Open site navigation',
} = Astro.props;

const preset = menuPresets[page];
const resolvedRoundItems = [...(roundItems ?? preset.roundItems), ...extraRoundItems];
const resolvedLineItems = [...(lineItems ?? preset.lineItems), ...extraLineItems];

const normalizePath = (path: string) => path.split('#')[0].replace(/\/$/, '') || '/';
const activeMatches = (href: string) => !href.includes('#') && normalizePath(href) === normalizePath(activePath);

const icons: Record<string, string[]> = {
  overview: ['M3.5 11.3 12 4.5l8.5 6.8', 'M5.5 10.5v9h5v-5h3v5h5v-9'],
  start: ['M12 4.5v15', 'M6.5 10l5.5-5.5 5.5 5.5', 'M7 19.5h10'],
  budget: ['M4.5 7.5h13a2.5 2.5 0 0 1 2.5 2.5v8H6.5A3.5 3.5 0 0 1 3 14.5v-7A3.5 3.5 0 0 1 6.5 4h11v3.5', 'M16 13h4'],
  simulator: ['M4.5 19.5v-15', 'M4.5 19.5h15', 'M7.5 15.5l3.7-4 3.1 2.6 4.2-6.6'],
  pillars: ['M5.5 19.5v-10', 'M12 19.5v-15', 'M18.5 19.5v-11', 'M4 19.5h16'],
  rules: ['M5 7h14', 'M5 12h14', 'M5 17h10'],
  positions: ['M5.5 19.5v-14h13v14', 'M8.5 9.5h7', 'M8.5 13h7', 'M8.5 16.5h4'],
  gears: ['M5 8h14', 'M5 16h14', 'M9 5.5v5', 'M15 13.5v5'],
  lifecycle: ['M7 7a7 7 0 0 1 10 0l2 2', 'M17 3v4h4', 'M17 17a7 7 0 0 1-10 0l-2-2', 'M7 21v-4H3'],
  cashflow: ['M4.5 8h15v10h-15z', 'M12 8v10', 'M7.5 13h1', 'M15.5 13h1'],
  weekly: ['M7 4.5v3', 'M17 4.5v3', 'M4.5 9h15', 'M6.5 6h11A2.5 2.5 0 0 1 20 8.5v9A2.5 2.5 0 0 1 17.5 20h-11A2.5 2.5 0 0 1 4 17.5v-9A2.5 2.5 0 0 1 6.5 6z'],
  contribution: ['M12 4.5v15', 'M8.5 8.5h5.3a2.2 2.2 0 0 1 0 4.4h-3.6a2.2 2.2 0 0 0 0 4.4h5.3'],
  expenses: ['M6 5h12v14H6z', 'M8.5 9h7', 'M8.5 12.5h7', 'M8.5 16h4'],
  flow: ['M5 7h8a3 3 0 0 1 0 6H8', 'M8 10l-3 3 3 3', 'M19 17h-8a3 3 0 0 1 0-6h5', 'M16 8l3 3-3 3'],
  examples: ['M5 5.5h6a3 3 0 0 1 3 3v11a3 3 0 0 0-3-3H5z', 'M14 8.5a3 3 0 0 1 3-3h2v11h-2a3 3 0 0 0-3 3'],
};

const id = `radial-site-menu-${Math.random().toString(36).slice(2)}`;

type LayerSpec = {
  radius: number;
  blueCount: number;
  redCount: number;
  blueStartAngle: number;
  blueEndAngle: number;
  redAngle: number;
};

const getLayerSpecs = (blueTotal: number, redTotal: number): LayerSpec[] => {
  const layers: LayerSpec[] = [];
  let blueRemaining = blueTotal;
  let redRemaining = redTotal;
  let layerIndex = 0;

  while (blueRemaining > 0 || redRemaining > 0) {
    const blueCapacity = 3 + layerIndex * 2;
    const blueCount = Math.min(blueCapacity, blueRemaining);
    const redCount = redRemaining > 0 ? 1 : 0;

    layers.push({
      radius: 3.45 + layerIndex * 1.72,
      blueCount,
      redCount,
      blueStartAngle: Math.max(98 - layerIndex * 6, 82),
      blueEndAngle: Math.min(194 + layerIndex * 8, 216),
      redAngle: Math.max(44 - layerIndex * 4, 28),
    });

    blueRemaining -= blueCount;
    redRemaining -= redCount;
    layerIndex += 1;
  }

  return layers;
};

const layerSpecs = getLayerSpecs(resolvedRoundItems.length, resolvedLineItems.length);

const toStyle = (angle: number, radius: number, delay: number, z: number) => {
  const radians = (angle * Math.PI) / 180;
  const x = Math.cos(radians) * radius;
  const y = -Math.sin(radians) * radius;
  return `--x: ${x.toFixed(2)}rem; --y: ${y.toFixed(2)}rem; --delay: ${delay}ms; --z: ${z};`;
};

const roundItemStyles: string[] = [];
const lineItemStyles: string[] = [];
let blueIndex = 0;
let redIndex = 0;

for (const layer of layerSpecs) {
  for (let index = 0; index < layer.blueCount; index += 1) {
    const angle = layer.blueCount <= 1
      ? (layer.blueStartAngle + layer.blueEndAngle) / 2
      : layer.blueStartAngle + ((layer.blueEndAngle - layer.blueStartAngle) * index) / (layer.blueCount - 1);
    roundItemStyles.push(toStyle(angle, layer.radius, (resolvedRoundItems.length - blueIndex - 1) * 42, 20 - blueIndex));
    blueIndex += 1;
  }

  for (let index = 0; index < layer.redCount; index += 1) {
    lineItemStyles.push(toStyle(layer.redAngle, layer.radius, 180 + redIndex * 34, 40 - redIndex));
    redIndex += 1;
  }
}
---

<nav id={id} class="radial-site-menu" aria-label="Site navigation">
  <div class="radial-site-menu__round">
    {layerSpecs.map((layer) => (
      <span class="radial-site-menu__arc-guide" style={`--arc-radius: ${layer.radius}rem;`} aria-hidden="true"></span>
    ))}
    {resolvedRoundItems.map((item, index) => (
      <a class:list={['radial-site-menu__item', 'is-round', { 'is-active': activeMatches(item.href) }]} data-menu-href={item.href} style={roundItemStyles[index]} href={item.href} aria-label={item.label} title={item.label} aria-current={activeMatches(item.href) ? 'page' : undefined}>
        <span class="radial-site-menu__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            {(icons[item.icon] ?? icons.overview).map((path) => <path d={path} />)}
          </svg>
        </span>
        <span class="radial-site-menu__label">{item.label}</span>
      </a>
    ))}
  </div>

  <div class="radial-site-menu__line">
    {resolvedLineItems.map((item, index) => (
      <a class:list={['radial-site-menu__item', 'is-line', { 'is-active': activeMatches(item.href) }]} data-menu-href={item.href} style={lineItemStyles[index]} href={item.href} aria-label={item.label} title={item.label} aria-current={activeMatches(item.href) ? 'page' : undefined}>
        <span class="radial-site-menu__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            {(icons[item.icon] ?? icons.overview).map((path) => <path d={path} />)}
          </svg>
        </span>
        <span class="radial-site-menu__label">{item.label}</span>
      </a>
    ))}
  </div>

  <button class="radial-site-menu__trigger" type="button" aria-label={label} aria-expanded="false">
    <svg class="radial-site-menu__mark" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round">
      <path class="radial-site-menu__bar radial-site-menu__bar--top" d="M5 7h14" />
      <path class="radial-site-menu__bar radial-site-menu__bar--middle" d="M5 12h14" />
      <path class="radial-site-menu__bar radial-site-menu__bar--bottom" d="M5 17h14" />
    </svg>
  </button>
</nav>

<script define:vars={{ id }}>
  const menu = document.getElementById(id);
  const trigger = menu?.querySelector('.radial-site-menu__trigger');
  const close = () => {
    menu?.classList.remove('is-open');
    trigger?.setAttribute('aria-expanded', 'false');
  };

  trigger?.addEventListener('click', (event) => {
    event.stopPropagation();
    const isOpen = menu.classList.toggle('is-open');
    trigger.setAttribute('aria-expanded', String(isOpen));
  });

  menu?.addEventListener('click', (event) => {
    if (event.target instanceof Element && event.target.closest('a')) close();
  });

  document.addEventListener('click', (event) => {
    if (menu && !menu.contains(event.target)) close();
  });

  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') return;
    close();
  });

  const samePageHashLinks = [...(menu?.querySelectorAll('[data-menu-href*="#"]') ?? [])]
    .filter((link) => {
      const url = new URL(link.getAttribute('href'), window.location.href);
      return url.pathname.replace(/\/$/, '') === window.location.pathname.replace(/\/$/, '');
    });

  if ('IntersectionObserver' in window && samePageHashLinks.length) {
    const linksById = new Map();
    for (const link of samePageHashLinks) {
      const id = new URL(link.getAttribute('href'), window.location.href).hash.slice(1);
      const section = document.getElementById(id);
      if (section) linksById.set(id, link);
    }

    const setCurrent = (id) => {
      for (const link of samePageHashLinks) {
        link.classList.remove('is-current-section');
        if (link.getAttribute('aria-current') === 'location') link.removeAttribute('aria-current');
      }
      const active = linksById.get(id);
      active?.classList.add('is-current-section');
      active?.setAttribute('aria-current', 'location');
    };

    const observer = new IntersectionObserver((entries) => {
      const visible = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
      if (visible?.target?.id) setCurrent(visible.target.id);
    }, { rootMargin: '-20% 0px -55% 0px', threshold: [0.08, 0.18, 0.32] });

    for (const id of linksById.keys()) observer.observe(document.getElementById(id));
  }
</script>

<style>
  .radial-site-menu {
    --shadow: 0.32rem 0.34rem 0.1rem rgba(42, 31, 13, 0.2);
    --trigger-size: 72px;
    --item-size: 3.1rem;
    position: fixed;
    right: clamp(1.1rem, 4vw, 2.5rem);
    bottom: clamp(1.1rem, 4vw, 2.5rem);
    z-index: 80;
    width: var(--trigger-size);
    height: var(--trigger-size);
  }

  .radial-site-menu__round,
  .radial-site-menu__line {
    position: absolute;
    right: 0;
    bottom: 0;
    width: var(--trigger-size);
    height: var(--trigger-size);
  }

  .radial-site-menu__round { z-index: 3; }
  .radial-site-menu__line { z-index: 3; }

  .radial-site-menu__arc-guide {
    position: absolute;
    right: calc(0.7rem + (var(--item-size) / 2) - var(--arc-radius));
    bottom: calc(0.7rem + (var(--item-size) / 2) - var(--arc-radius));
    width: calc(var(--arc-radius) * 2);
    height: calc(var(--arc-radius) * 2);
    border: 1px solid rgba(32, 63, 105, 0.18);
    border-radius: 999px;
    opacity: 0;
    pointer-events: none;
    transform: scale(0.92);
    transition:
      opacity 220ms ease-out,
      transform 420ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .radial-site-menu.is-open .radial-site-menu__arc-guide {
    opacity: 0.3;
    transform: scale(1);
  }

  .radial-site-menu__trigger,
  .radial-site-menu__item {
    border: 0;
    border-radius: 999px;
    display: grid;
    place-items: center;
    cursor: pointer;
    color: var(--paper, #fffdf7);
    outline: none;
    -webkit-tap-highlight-color: transparent;
  }

  .radial-site-menu__trigger {
    position: absolute;
    right: 0;
    bottom: 0;
    z-index: 5;
    width: var(--trigger-size);
    height: var(--trigger-size);
    background: radial-gradient(circle at 32% 24%, color-mix(in srgb, var(--b, #bf7327) 92%, white), var(--b, #bf7327) 62%, #8d4717);
    box-shadow: var(--shadow), 0 0 0 8px rgba(255, 253, 247, 0.55);
    transition: transform 360ms cubic-bezier(0.16, 1, 0.3, 1), filter 180ms ease-out;
  }

  .radial-site-menu__trigger:hover,
  .radial-site-menu__trigger:focus-visible {
    filter: saturate(1.08) brightness(1.02);
    transform: translateY(-2px);
  }

  .radial-site-menu__mark {
    width: 2.45rem;
    height: 2.45rem;
    overflow: visible;
  }

  .radial-site-menu__bar {
    fill: none;
    stroke: currentColor;
    stroke-width: 2.8;
    stroke-linecap: round;
    transform-box: fill-box;
    transform-origin: center;
    transition: transform 390ms cubic-bezier(0.16, 1, 0.3, 1), opacity 180ms ease-out;
  }

  .radial-site-menu__item {
    position: absolute;
    right: 0.7rem;
    bottom: 0.7rem;
    width: var(--item-size);
    height: var(--item-size);
    grid-template-columns: var(--item-size) 0fr;
    justify-content: start;
    overflow: hidden;
    font: 950 0.98rem/1 var(--mono, ui-monospace, SFMono-Regular, Menlo, Consolas, monospace);
    text-decoration: none;
    background: linear-gradient(145deg, var(--a, #203f69), #315f99);
    box-shadow: none;
    transform: translate(0, 0) scale(0.65);
    opacity: 0;
    pointer-events: none;
    z-index: var(--z, 1);
    transition: width 320ms cubic-bezier(0.16, 1, 0.3, 1), transform 390ms cubic-bezier(0.16, 1, 0.3, 1), opacity 160ms ease-out, box-shadow 160ms ease-out, filter 160ms ease-out;
  }

  .radial-site-menu__icon {
    display: grid;
    place-items: center;
    width: var(--item-size);
    height: var(--item-size);
    flex: 0 0 var(--item-size);
  }

  .radial-site-menu__icon svg {
    width: 1.45rem;
    height: 1.45rem;
  }

  .radial-site-menu__label {
    display: block;
    max-width: 0;
    padding-right: 0;
    overflow: hidden;
    white-space: nowrap;
    opacity: 0;
    transform: translateX(-0.35rem);
    transition:
      max-width 320ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 180ms ease-out,
      transform 320ms cubic-bezier(0.16, 1, 0.3, 1),
      padding-right 320ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .radial-site-menu__item:hover,
  .radial-site-menu__item:focus-visible {
    width: max-content;
    min-width: 9.75rem;
    grid-template-columns: var(--item-size) 1fr;
    filter: brightness(1.06) saturate(1.08);
    z-index: 20;
  }

  .radial-site-menu__item:hover .radial-site-menu__label,
  .radial-site-menu__item:focus-visible .radial-site-menu__label {
    max-width: 8rem;
    padding-right: 1.05rem;
    opacity: 1;
    transform: translateX(0);
  }

  .radial-site-menu__item.is-line {
    background: linear-gradient(145deg, var(--d, #aa463d), #87332c);
    transition-duration: 300ms;
    transition-delay: 220ms;
  }

  .radial-site-menu__item.is-active,
  .radial-site-menu__item.is-current-section {
    box-shadow: var(--shadow), 0 0 0 4px color-mix(in srgb, var(--gold, #c79a2c) 44%, transparent);
  }

  .radial-site-menu__item.is-current-section::after {
    content: '';
    position: absolute;
    right: 0.58rem;
    top: 0.58rem;
    width: 0.46rem;
    height: 0.46rem;
    border-radius: 999px;
    background: var(--gold, #c79a2c);
  }

  .radial-site-menu.is-open .radial-site-menu__bar--top { transform: translateY(5px) rotate(45deg); }
  .radial-site-menu.is-open .radial-site-menu__bar--middle { opacity: 0; transform: scaleX(0.35); }
  .radial-site-menu.is-open .radial-site-menu__bar--bottom { transform: translateY(-5px) rotate(-45deg); }

  .radial-site-menu.is-open .radial-site-menu__item {
    opacity: 1;
    pointer-events: auto;
    box-shadow: var(--shadow);
  }

  .radial-site-menu.is-open .radial-site-menu__item.is-round {
    transform: translate(var(--x), var(--y)) scale(1);
    transition-delay: var(--delay);
  }

  .radial-site-menu.is-open .radial-site-menu__item.is-line {
    transform: translate(var(--x), var(--y)) scale(1);
    transition-delay: var(--delay);
  }

  @media (prefers-reduced-motion: reduce) {
    .radial-site-menu__trigger,
    .radial-site-menu__bar,
    .radial-site-menu__item {
      transition-duration: 1ms;
      transition-delay: 0ms;
    }
  }
</style>
