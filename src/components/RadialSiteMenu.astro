---
type MenuItem = {
  label: string;
  icon: string;
  href: string;
};

type MenuPage = 'home' | 'getting-started' | 'budget' | 'simulator' | 'demo-10';

interface Props {
  /** Page preset to use when custom items are not provided. */
  page?: MenuPage;
  /** Replace the radial priority actions. */
  roundItems?: MenuItem[];
  /** Replace the vertical section actions. */
  lineItems?: MenuItem[];
  /** Append extra actions without rebuilding the preset. */
  extraRoundItems?: MenuItem[];
  extraLineItems?: MenuItem[];
  /** Override current path for active-state matching. Defaults to Astro.url.pathname. */
  activePath?: string;
  label?: string;
}

const menuPresets: Record<MenuPage, { roundItems: MenuItem[]; lineItems: MenuItem[] }> = {
