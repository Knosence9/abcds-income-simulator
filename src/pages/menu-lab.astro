---
import { ViewTransitions } from 'astro:transitions';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Radial Menu Layout Lab</title>
    <ViewTransitions />
    <style is:global>
      :root {
        --bg:#f6f0e4; --paper:#fffdf7; --ink:#17243a; --muted:#617086; --line:rgba(23,36,58,.15);
        --a:#203f69; --b:#bf7327; --d:#aa463d; --gold:#c79a2c; --shadow:0 28px 90px rgba(42,31,13,.15);
        --mono:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace; --sans:ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
      }
      * { box-sizing:border-box; }
      body {
        margin:0; font-family:var(--sans); color:var(--ink);
        background:
          radial-gradient(circle at 10% 5%, rgba(199,154,44,.22), transparent 27rem),
          radial-gradient(circle at 88% 13%, rgba(32,63,105,.16), transparent 26rem),
          linear-gradient(90deg, rgba(23,36,58,.035) 1px, transparent 1px),
          linear-gradient(rgba(23,36,58,.035) 1px, transparent 1px),
          var(--bg);
        background-size:auto, auto, 30px 30px, 30px 30px, auto;
      }
      .shell { width:min(1400px, calc(100vw - 28px)); margin:0 auto; padding:22px 0 56px; }
      .topbar { display:flex; gap:12px; align-items:center; justify-content:space-between; margin-bottom:16px; }
      .pill, .ui-button {
        border:1px solid var(--line); border-radius:999px; background:rgba(255,255,255,.6); color:var(--a);
        min-height:42px; padding:0 14px; font:850 13px var(--sans); cursor:pointer;
      }
      .layout { display:grid; grid-template-columns:minmax(320px, 420px) minmax(420px, 1fr); gap:18px; align-items:start; }
      .panel {
        border:1px solid var(--line); border-radius:28px; background:rgba(255,253,247,.92); box-shadow:var(--shadow); padding:22px;
      }
      h1 { margin:0 0 10px; font-size:32px; color:var(--a); }
      p { margin:0 0 12px; color:#49576c; line-height:1.55; }
      .stack { display:grid; gap:12px; }
      .controls { display:grid; gap:10px; }
      .row { display:flex; gap:10px; flex-wrap:wrap; }
      textarea {
        width:100%; min-height:240px; resize:vertical; border:1px solid var(--line); border-radius:18px; padding:14px;
        background:var(--paper); color:var(--ink); font:13px/1.45 var(--mono);
      }
      .note { font-size:13px; color:var(--muted); }
      .stage {
        position:relative; min-height:740px; overflow:hidden;
        background:linear-gradient(180deg, rgba(255,253,247,.72), rgba(255,253,247,.52));
      }
      .stage::before {
        content:''; position:absolute; inset:18px; border:1px dashed rgba(32,63,105,.16); border-radius:22px; pointer-events:none;
      }
      .lab {
        position:absolute; right:32px; bottom:32px; width:560px; height:560px;
      }
      .guide {
        position:absolute; right:36px; bottom:36px; border-radius:999px; border:1px solid rgba(32,63,105,.12); pointer-events:none;
        transform:translate(50%, 50%);
      }
      .axis {
        position:absolute; right:71px; bottom:71px; width:1px; height:470px; background:rgba(32,63,105,.08); pointer-events:none;
      }
      .item {
        position:absolute; width:50px; height:50px; border:0; padding:0; appearance:none; border-radius:999px; display:grid; place-items:center; color:var(--paper);
        box-shadow:0.32rem 0.34rem 0.1rem rgba(42,31,13,.2); user-select:none; touch-action:none; cursor:grab;
      }
      .item:active { cursor:grabbing; }
      .item.blue { background:linear-gradient(145deg, var(--a), #315f99); }
      .item.red { background:linear-gradient(145deg, var(--d), #87332c); }
      .item.trigger {
        right:0; bottom:0; width:72px; height:72px; background:radial-gradient(circle at 32% 24%, color-mix(in srgb, var(--b) 92%, white), var(--b) 62%, #8d4717);
        box-shadow:0.32rem 0.34rem 0.1rem rgba(42,31,13,.2), 0 0 0 8px rgba(255,253,247,.55); cursor:default;
      }
      .item svg { width:24px; height:24px; stroke:currentColor; fill:none; stroke-width:2.2; stroke-linecap:round; stroke-linejoin:round; pointer-events:none; }
      .item.trigger svg { width:34px; height:34px; stroke-width:2.8; }
      .tag {
        position:absolute; top:54px; left:50%; transform:translateX(-50%); padding:2px 7px; border-radius:999px;
        background:rgba(255,253,247,.94); border:1px solid rgba(23,36,58,.1); color:var(--a); font:800 11px var(--mono); white-space:nowrap;
      }
      .ghost {
        position:absolute; right:36px; bottom:36px; width:50px; height:50px; border-radius:999px; border:1px dashed rgba(32,63,105,.18);
        pointer-events:none; transform:translate(50%, 50%);
      }
      @media (max-width: 1100px) {
        .layout { grid-template-columns:1fr; }
        .lab { width:min(560px, calc(100vw - 90px)); height:min(560px, calc(100vw - 90px)); }
        .stage { min-height:680px; }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <div class="topbar">
        <a class="pill" href="/simulator">← Back to simulator</a>
        <button class="ui-button" id="copyConfig" type="button">Copy layout JSON</button>
      </div>

      <div class="layout">
        <section class="panel stack">
          <div>
            <h1>Radial menu layout lab</h1>
            <p>Yes, this lets you move the buttons directly. Drag the blue and red buttons into the exact shape you want. Then copy the JSON and send it back to me.</p>
            <p class="note">The trigger stays fixed. Coordinates are stored relative to the trigger center, in pixels, so I can wire them straight into the component after you place them.</p>
          </div>
          <div class="controls">
            <div class="row">
              <button class="ui-button" id="resetLayout" type="button">Reset layout</button>
              <button class="ui-button" id="toggleGuides" type="button">Hide guides</button>
            </div>
            <textarea id="configOutput" spellcheck="false"></textarea>
          </div>
        </section>

        <section class="panel stage">
          <div class="lab" id="lab">
            <div class="axis"></div>
            <div class="guide" style="width:160px;height:160px;"></div>
            <div class="guide" style="width:260px;height:260px;"></div>
            <div class="guide" style="width:360px;height:360px;"></div>
            <div class="ghost"></div>
            <div class="item trigger">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6l12 12" /><path d="M18 6 6 18" /></svg>
            </div>
          </div>
        </section>
      </div>
    </div>

    <script>
      const seed = {
        blue: [
          { label: 'B1', x: -39, y: -72 },
          { label: 'B2', x: -74, y: -25 },
          { label: 'B3', x: -69, y: 32 },
          { label: 'B4', x: -37, y: -124 },
          { label: 'B5', x: -85, y: -98 },
          { label: 'B6', x: -120, y: -54 },
          { label: 'B7', x: -126, y: 4 },
          { label: 'B8', x: -37, y: -184 },
        ],
        red: [
          { label: 'R1', x: 21, y: -79 },
          { label: 'R2', x: 21, y: -130 },
        ],
      };

      const icons = {
        blue: ['M5 12h14', 'M12 5v14'],
        red: ['M7 7h10', 'M7 12h10', 'M7 17h10'],
      };

      const lab = document.getElementById('lab');
      const output = document.getElementById('configOutput');
      const copyButton = document.getElementById('copyConfig');
      const resetButton = document.getElementById('resetLayout');
      const toggleGuidesButton = document.getElementById('toggleGuides');
      const guides = [...lab.querySelectorAll('.guide, .axis, .ghost')];
      let guidesVisible = true;
      let state = JSON.parse(JSON.stringify(seed));

      const makeIcon = (kind) => {
        const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        svg.setAttribute('viewBox', '0 0 24 24');
        for (const d of icons[kind]) {
          const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
          path.setAttribute('d', d);
          svg.appendChild(path);
        }
        return svg;
      };

      const updateOutput = () => {
        output.value = JSON.stringify(state, null, 2);
      };

      const getAnchor = () => ({ x: lab.clientWidth - 36, y: lab.clientHeight - 36 });

      const place = (el, item) => {
        const anchor = getAnchor();
        const size = el.classList.contains('trigger') ? 72 : 50;
        el.style.left = `${anchor.x + item.x - (size / 2)}px`;
        el.style.top = `${anchor.y + item.y - (size / 2)}px`;
      };

      const render = () => {
        [...lab.querySelectorAll('.item.draggable')].forEach((node) => node.remove());
        ['blue', 'red'].forEach((kind) => {
          state[kind].forEach((item, index) => {
            const el = document.createElement('div');
            el.className = `item draggable ${kind}`;
            el.dataset.kind = kind;
            el.dataset.index = String(index);
            el.style.position = 'absolute';
            el.style.width = '50px';
            el.style.height = '50px';
            el.style.borderRadius = '999px';
            el.style.display = 'grid';
            el.style.placeItems = 'center';
            el.style.color = 'var(--paper)';
            el.style.boxShadow = '0.32rem 0.34rem 0.1rem rgba(42,31,13,.2)';
            el.style.userSelect = 'none';
            el.style.touchAction = 'none';
            el.style.cursor = 'grab';
            el.style.background = kind === 'blue'
              ? 'linear-gradient(145deg, var(--a), #315f99)'
              : 'linear-gradient(145deg, var(--d), #87332c)';
            el.appendChild(makeIcon(kind));
            const tag = document.createElement('span');
            tag.className = 'tag';
            tag.textContent = item.label;
            el.appendChild(tag);
            place(el, item);
            enableDrag(el);
            lab.appendChild(el);
          });
        });
        updateOutput();
      };

      const enableDrag = (el) => {
        el.addEventListener('pointerdown', (event) => {
          const { kind, index } = el.dataset;
          const item = state[kind][Number(index)];
          const startX = event.clientX;
          const startY = event.clientY;
          const originX = item.x;
          const originY = item.y;
          el.setPointerCapture(event.pointerId);

          const onMove = (moveEvent) => {
            item.x = Math.round(originX + (moveEvent.clientX - startX));
            item.y = Math.round(originY + (moveEvent.clientY - startY));
            place(el, item);
            updateOutput();
          };

          el.style.cursor = 'grabbing';

          const onUp = () => {
            el.style.cursor = 'grab';
            el.removeEventListener('pointermove', onMove);
            el.removeEventListener('pointerup', onUp);
            el.removeEventListener('pointercancel', onUp);
          };

          el.addEventListener('pointermove', onMove);
          el.addEventListener('pointerup', onUp);
          el.addEventListener('pointercancel', onUp);
        });
      };

      copyButton.addEventListener('click', async () => {
        updateOutput();
        await navigator.clipboard.writeText(output.value);
        copyButton.textContent = 'Copied';
        setTimeout(() => { copyButton.textContent = 'Copy layout JSON'; }, 1200);
      });

      resetButton.addEventListener('click', () => {
        state = JSON.parse(JSON.stringify(seed));
        render();
      });

      toggleGuidesButton.addEventListener('click', () => {
        guidesVisible = !guidesVisible;
        guides.forEach((guide) => { guide.style.display = guidesVisible ? '' : 'none'; });
        toggleGuidesButton.textContent = guidesVisible ? 'Hide guides' : 'Show guides';
      });

      window.addEventListener('resize', render);
      render();
    </script>
  </body>
</html>
