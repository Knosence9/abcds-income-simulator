        const paycheck = $('paycheck');
        const paycheckNumber = $('paycheckNumber');
        paycheck.value = transferredContribution;
        const appliedContribution = Number(paycheck.value);
        paycheckNumber.value = String(appliedContribution);

        const requestedMarginRepair = searchParams.get('weeklyMarginRepair');
        const requestedMarginRepairNumber = Number(requestedMarginRepair);
        const transferredMarginRepair = parseWeeklyContribution(
          requestedMarginRepair,
          { fallback: 0, max: 5000 },
