---
import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';
import RadialSiteMenu from '../components/RadialSiteMenu.astro';
import ReaderNavigation from '../components/ReaderNavigation.astro';
import SkipLink from '../components/SkipLink.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteMetadata from '../components/SiteMetadata.astro';
import { buildPageMetadata } from '../lib/site-metadata.mjs';

const metadata = buildPageMetadata('/simulator/');

const defaultInputs = {
  starting: 60450,
  marginDebt: 0,
  marginApr: 10,
  weeklyMarginRepair: 0,
  paycheck: 750,
  anchorAllocation: 30,
  anchorYield: 4,
  boosterAllocation: 20,
  boosterYield: 9,
  closedEndAllocation: 30,
  closedEndYield: 12,
  dynamoAllocation: 20,
  dynamoYield: 18,
  marketShock: 0,
  distributionCut: 0,
  dividendGrowth: 4,
  annualNavReturn: 3,
  inflation: 7,
  monthlyExpenses: 2600,
  projectionYears: 5,
};


---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SiteMetadata metadata={metadata} />
    <ClientRouter />
    <style>
      :root { --bg:#f6f0e4; --paper:#fffdf7; --paper-2:#fbf6ea; --ink:#17243a; --muted:#617086; --line:rgba(23,36,58,.15); --a:#203f69; --b:#bf7327; --c:#617f3e; --d:#aa463d; --gold:#c79a2c; --shadow:0 28px 90px rgba(42,31,13,.15); --serif:Georgia,'Times New Roman',serif; --sans:ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; --mono:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace; }
      * { box-sizing:border-box; }
      html { scroll-behavior:smooth; }
      body { margin:0; font-family:var(--sans); color:var(--ink); background:radial-gradient(circle at 10% 5%, rgba(199,154,44,.22), transparent 27rem), radial-gradient(circle at 88% 13%, rgba(32,63,105,.16), transparent 26rem), radial-gradient(circle at 75% 90%, rgba(97,127,62,.14), transparent 24rem), linear-gradient(90deg, rgba(23,36,58,.035) 1px, transparent 1px), linear-gradient(rgba(23,36,58,.035) 1px, transparent 1px), var(--bg); background-size:auto, auto, auto, 30px 30px, 30px 30px, auto; }
      a { color:inherit; }
      .shell { width:min(1440px, calc(100vw - 28px)); margin:0 auto; padding:22px 0 64px; }
      .topbar { display:flex; justify-content:space-between; gap:12px; align-items:center; margin-bottom:14px; }
      .pill { border:1px solid var(--line); border-radius:999px; padding:9px 12px; background:rgba(255,255,255,.55); text-decoration:none; color:var(--a); font-weight:850; font-size:13px; }
      .donate-link { display:inline-flex; align-items:center; gap:9px; min-height:42px; border:1px solid color-mix(in srgb, var(--b) 42%, transparent); border-radius:999px; padding:0 15px; background:color-mix(in srgb, var(--b) 12%, var(--paper)); color:var(--a); text-decoration:none; font-weight:950; box-shadow:0 12px 28px rgba(42,31,13,.1); }
      .donate-link::before { content:'$'; display:grid; place-items:center; width:26px; height:26px; border-radius:999px; background:var(--b); color:var(--paper); font:950 14px var(--mono); }
      .donate-link:hover { transform:translateY(-1px); box-shadow:0 16px 34px rgba(42,31,13,.14); }
      .hero, .panel { border:1px solid var(--line); border-radius:34px; background:rgba(255,253,247,.91); box-shadow:var(--shadow); overflow:hidden; }
      .hero { padding:clamp(28px, 5vw, 58px); margin-bottom:28px; position:relative; }
      .hero::before { content:""; position:absolute; inset:22px; border:1px dashed rgba(32,63,105,.18); border-radius:26px; pointer-events:none; }
      .eyebrow { font:850 12px var(--mono); letter-spacing:.14em; text-transform:uppercase; color:var(--d); }
      h1 { margin:12px 0 18px; font:950 clamp(46px, 8vw, 96px)/.88 var(--serif); letter-spacing:-.06em; color:var(--a); max-width:12ch; }
      h2 { margin:0; font:950 clamp(30px, 5vw, 62px)/.92 var(--serif); letter-spacing:-.045em; color:var(--a); }
      p { color:#49576c; line-height:1.58; }
      .lead { font-size:clamp(18px, 2vw, 24px); max-width:860px; }
      .hero-actions { display:flex; gap:10px; flex-wrap:wrap; margin-top:24px; }
      .button { display:inline-flex; align-items:center; justify-content:center; min-height:44px; border-radius:999px; padding:0 16px; text-decoration:none; font-weight:900; border:1px solid var(--line); cursor:pointer; }
      .button.primary { background:var(--a); color:var(--paper); border-color:var(--a); }
      .button.secondary { background:rgba(255,255,255,.6); color:var(--a); }
      .panel { padding:clamp(24px, 4vw, 48px); }
      .section-head { display:flex; align-items:end; justify-content:space-between; gap:16px; margin-bottom:24px; }
      .sim { position:relative; display:block; }
      .controls-toggle { display:inline-flex; align-items:center; justify-content:center; gap:10px; min-height:54px; margin-bottom:14px; border:2px solid rgba(255,253,247,.9); border-radius:999px; padding:0 22px; background:linear-gradient(135deg, var(--a), #315f99); color:var(--paper); font-weight:950; font-size:16px; cursor:pointer; box-shadow:0 16px 38px rgba(32,63,105,.28), 0 0 0 5px rgba(32,63,105,.10); animation:pulseHint 2.4s ease-in-out infinite; }
      .controls-toggle::before { content:'☰'; font-size:18px; }
      @keyframes pulseHint { 0%,100% { transform:translateY(0); box-shadow:0 16px 38px rgba(32,63,105,.28), 0 0 0 5px rgba(32,63,105,.10); } 50% { transform:translateY(-1px); box-shadow:0 20px 44px rgba(32,63,105,.34), 0 0 0 8px rgba(191,115,39,.14); } }
      .controls { position:absolute; left:16px; top:58px; z-index:10; width:min(390px, calc(100% - 32px)); max-height:min(680px, calc(100vh - 120px)); overflow:auto; border:1px solid var(--line); border-radius:26px; padding:18px; background:rgba(251,246,234,.96); backdrop-filter:blur(18px); box-shadow:0 26px 80px rgba(42,31,13,.22); opacity:0; pointer-events:none; transform:translateY(-8px) scale(.98); transition:opacity .18s ease, transform .18s ease; }
      .sim.controls-open .controls { opacity:1; pointer-events:auto; transform:translateY(0) scale(1); }
      .field { display:grid; gap:7px; margin-bottom:14px; }
      .field label { display:flex; align-items:center; justify-content:space-between; gap:12px; font-weight:850; color:var(--a); }
      .field input[type='range'] { width:100%; accent-color:var(--a); }
      .field input[type='number'] { width:130px; border:1px solid var(--line); border-radius:12px; padding:8px 10px; background:var(--paper); color:var(--ink); font:800 14px var(--mono); }
      .scenario-presets { margin-bottom:18px; border:0; padding:0; }
      .scenario-presets legend { margin-bottom:8px; font-weight:900; color:var(--a); }
      .scenario-buttons { display:flex; flex-wrap:wrap; gap:8px; }
      .scenario-button { min-height:40px; border:1px solid var(--line); border-radius:999px; padding:0 13px; background:var(--paper); color:var(--a); font-weight:850; cursor:pointer; }
      .scenario-button[aria-pressed='true'] { border-color:var(--a); background:var(--a); color:var(--paper); }
      .allocation-snapshot { margin:0 0 18px; border:1px solid var(--line); border-radius:20px; padding:14px; background:rgba(255,255,255,.55); }
      .allocation-snapshot legend { padding:0 5px; font-weight:900; color:var(--a); }
      .allocation-snapshot-grid { display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:10px; }
      .snapshot-field { display:grid; gap:5px; color:var(--a); font-size:13px; font-weight:850; }
      .snapshot-field input, .snapshot-field textarea { width:100%; min-width:0; border:1px solid var(--line); border-radius:12px; padding:9px 10px; background:var(--paper); color:var(--ink); font:800 14px var(--mono); }
      .snapshot-field textarea { min-height:96px; resize:vertical; }
      .snapshot-field textarea[aria-invalid='true'] { border-color:var(--d); outline:2px solid color-mix(in srgb, var(--d) 28%, transparent); }
      .allocation-snapshot .button { width:100%; margin-top:10px; }
      .allocation-snapshot .button:disabled { cursor:not-allowed; opacity:.55; }
      .snapshot-actions { display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:8px; }
      .chart-wrap { border:1px solid var(--line); border-radius:26px; background:linear-gradient(180deg, rgba(32,63,105,.05), rgba(255,253,247,.7)); padding:18px; min-height:560px; }
      .stats { display:grid; grid-template-columns:repeat(auto-fit, minmax(180px,1fr)); gap:10px; margin-bottom:14px; }
      .stat { border:1px solid var(--line); border-radius:18px; padding:12px; background:rgba(255,255,255,.62); }
      .stat strong { display:block; font:950 26px var(--serif); color:var(--a); }
      .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0; }
      svg { width:100%; height:auto; display:block; }
      .legend { display:flex; gap:10px; flex-wrap:wrap; margin-top:12px; color:var(--muted); font-size:13px; }
      .legend span { display:inline-flex; align-items:center; gap:7px; }
      .swatch { width:18px; height:4px; border-radius:999px; display:inline-block; }
      .methodology { margin-top:24px; border-top:1px solid var(--line); padding-top:24px; }
      .methodology h2 { font-size:clamp(28px, 4vw, 44px); }
      .methodology-grid { display:grid; grid-template-columns:repeat(2, minmax(0, 1fr)); gap:14px; margin-top:18px; }
      .methodology-card { border:1px solid var(--line); border-radius:22px; padding:18px; background:rgba(255,255,255,.5); }
      .methodology-card h3 { margin:0 0 8px; color:var(--a); }
      .methodology-card p { margin:0; }
      .callout { border-left:6px solid var(--gold); border-radius:18px; padding:16px 18px; background:rgba(199,154,44,.13); }
      .compact { min-height:auto; }
      .footer-note { margin-top:16px; color:var(--muted); font-size:13px; }
      @media (max-width: 900px) { .stats, .methodology-grid { grid-template-columns:1fr; } .section-head, .topbar { align-items:flex-start; flex-direction:column; } }
      @media (prefers-reduced-motion: reduce) { html { scroll-behavior:auto; } }
    </style>
  </head>
  <body>
    <SkipLink />
    <ReaderNavigation page="simulator" />
    <div class="shell">
      <div class="topbar"><a class="pill" href="/">← Back to main guide</a><a class="donate-link" href="https://cash.app/$knosence" target="_blank" rel="noopener noreferrer">Donate $knosence</a></div>

      <main id="main-content" tabindex="-1">
      <header class="hero" transition:name="hero">
        <div class="eyebrow">Projection lab</div>
        <h1>Run the income path projection.</h1>
        <p class="lead">Test contribution pace, yield assumptions, dividend growth, inflation, and expense targets without scrolling through the full guide.</p>
        <div class="hero-actions"><a class="button primary" href="#simulator">Open inputs</a><a class="button secondary" href="/getting-started">Start from zero</a><a class="button secondary" href="/budget">Budget first</a><a class="button secondary" href="/#gears">Choose a gear</a></div>
      </header>

      <section id="simulator" class="panel" transition:name="simulator-panel">
        <div class="section-head"><h2>Income path simulator</h2><span class="pill">start here: open inputs</span></div>
        <div class="sim" id="simulatorShell">
          <button class="controls-toggle" id="controlsToggle" type="button" aria-expanded="false" aria-controls="simulatorControls">Open simulator inputs</button>
          <aside class="controls" id="simulatorControls">
            <fieldset class="scenario-presets">
              <legend>Starting assumptions</legend>
              <div class="scenario-buttons">
                <button class="scenario-button" type="button" data-scenario="conservative" aria-pressed="false">Conservative</button>
                <button class="scenario-button" type="button" data-scenario="base" aria-pressed="false">Base</button>
                <button class="scenario-button" type="button" data-scenario="stress" aria-pressed="false">Stress</button>
              </div>
              <p class="footer-note">These presets fill transparent starting assumptions below. The stress preset applies an immediate synthetic 20% NAV/price shock. The stress preset includes a synthetic NAV/price decline. The stress preset applies an immediate 25% distribution cut.</p>
            </fieldset>
            <fieldset class="allocation-snapshot">
              <legend>Current ABCD allocation snapshot</legend>
              <p class="footer-note" id="allocationSnapshotPrivacy">Enter aggregate values only. Save stores only the four aggregate pillar balances, aggregate margin debt, and save time in this browser; no holdings, transactions, or account identifiers are stored or sent. Import and export processing stays local; exported files can be moved manually between browsers or devices. CSV is export-only; use JSON to import a snapshot.</p>
              <div class="allocation-snapshot-grid">
                <div class="snapshot-field"><label for="anchorBalance">Anchor balance</label><input id="anchorBalance" type="number" min="0" step="0.01" value="0" inputmode="decimal" aria-describedby="allocationSnapshotPrivacy" /></div>
                <div class="snapshot-field"><label for="boosterBalance">Booster balance</label><input id="boosterBalance" type="number" min="0" step="0.01" value="0" inputmode="decimal" aria-describedby="allocationSnapshotPrivacy" /></div>
                <div class="snapshot-field"><label for="closedEndBalance">Closed-end balance</label><input id="closedEndBalance" type="number" min="0" step="0.01" value="0" inputmode="decimal" aria-describedby="allocationSnapshotPrivacy" /></div>
                <div class="snapshot-field"><label for="dynamoBalance">Dynamo balance</label><input id="dynamoBalance" type="number" min="0" step="0.01" value="0" inputmode="decimal" aria-describedby="allocationSnapshotPrivacy" /></div>
                <div class="snapshot-field"><label for="snapshotMarginDebt">Starting margin debt</label><input id="snapshotMarginDebt" type="number" min="0" step="0.01" value="0" inputmode="decimal" aria-describedby="allocationSnapshotPrivacy" /></div>
              </div>
              <p id="allocationSnapshotSummary" class="footer-note" aria-live="polite">Enter at least one pillar balance to calculate weights.</p>
              <div class="snapshot-field">
                <label for="anonymousUnderlyingGroups">Anonymous underlying group tags</label>
                <textarea id="anonymousUnderlyingGroups" maxlength="5000" spellcheck="false" aria-describedby="duplicateUnderlyingPrivacy" placeholder={'group-1\ngroup-1\ngroup-2'}></textarea>
              </div>
              <p id="duplicateUnderlyingPrivacy" class="footer-note">Enter one synthetic group tag per position without fund names, symbols, account identifiers, or transactions. Group tags are not stored, exported, or sent.</p>
              <p id="duplicateUnderlyingStatus" class="footer-note" role="status" aria-live="polite" aria-atomic="true">Enter anonymous group tags to check duplicate underlying exposure.</p>
              <div class="snapshot-field">
                <label for="activeDynamoCount">Active Dynamo positions</label>
                <input id="activeDynamoCount" type="number" min="0" step="1" value="0" inputmode="numeric" aria-describedby="dynamoCountPrivacy" />
              </div>
              <p id="dynamoCountPrivacy" class="footer-note">Maximum four active Dynamos. This active Dynamo count is calculated locally in this browser. The active Dynamo count is not stored, exported, or sent.</p>
              <p id="dynamoCountStatus" class="footer-note" role="status" aria-live="polite" aria-atomic="true">0 active Dynamos is within the four-position cap.</p>
              <div class="snapshot-field">
                <label for="anonymousPositionValues">Anonymous position market values</label>
                <textarea id="anonymousPositionValues" inputmode="decimal" maxlength="5000" aria-describedby="positionConcentrationPrivacy" placeholder={'500\n700.01'}></textarea>
              </div>
              <p id="positionConcentrationPrivacy" class="footer-note">Enter one market value per line without names, symbols, account identifiers, or transactions. Anonymous position values are not stored, exported, or sent.</p>
              <p id="positionConcentrationStatus" class="footer-note" role="status" aria-live="polite" aria-atomic="true">Enter anonymous position values to check the 5% and 7% concentration limits.</p>
              <button id="applyAllocationSnapshot" class="button secondary" type="button" disabled>Use in projection</button>
              <div class="snapshot-actions">
                <button id="saveAllocationSnapshot" class="button secondary" type="button">Save in browser</button>
                <button id="resetAllocationSnapshot" class="button secondary" type="button">Reset saved snapshot</button>
                <button id="exportAllocationSnapshot" class="button secondary" type="button">Export snapshot JSON</button>
                <button id="exportAllocationSnapshotCsv" class="button secondary" type="button">Export snapshot CSV</button>
                <button id="importAllocationSnapshot" class="button secondary" type="button">Import snapshot JSON</button>
              </div>
              <input id="allocationSnapshotFile" type="file" accept="application/json,.json" hidden />
              <p id="allocationSnapshotStorageStatus" class="footer-note" aria-live="polite"></p>
            </fieldset>
            <div class="field"><label id="startingLabel" for="startingNumber">Starting gross market value <input id="startingNumber" type="number" value={defaultInputs.starting} min="0" step="0.01" /></label><input id="starting" type="range" aria-labelledby="startingLabel" value={defaultInputs.starting} min="0" max="250000" step="0.01" /></div>
            <div class="field"><label id="marginDebtLabel" for="marginDebtNumber">Starting margin debt <input id="marginDebtNumber" type="number" value={defaultInputs.marginDebt} min="0" max={defaultInputs.starting} step="0.01" /></label><input id="marginDebt" type="range" aria-labelledby="marginDebtLabel" value={defaultInputs.marginDebt} min="0" max={defaultInputs.starting} step="0.01" /></div>
            <div class="field"><label id="marginAprLabel" for="marginAprNumber">Margin APR <input id="marginAprNumber" type="number" value={defaultInputs.marginApr} min="0" max="30" step="0.1" /></label><input id="marginApr" type="range" aria-labelledby="marginAprLabel" value={defaultInputs.marginApr} min="0" max="30" step="0.1" /></div>
            <div class="field"><label id="weeklyMarginRepairLabel" for="weeklyMarginRepairNumber">Weekly margin repair <input id="weeklyMarginRepairNumber" type="number" value={defaultInputs.weeklyMarginRepair} min="0" max="5000" step="0.01" /></label><input id="weeklyMarginRepair" type="range" aria-labelledby="weeklyMarginRepairLabel" value={defaultInputs.weeklyMarginRepair} min="0" max="5000" step="0.01" /></div>
            <div class="callout compact"><b>Margin repair assumption:</b> the weekly amount becomes a smooth principal-only planning assumption. Interest is not capitalized or paid; it is estimated from beginning debt for each month. Real brokerage timing may differ.</div>
            <div class="field"><label id="paycheckLabel" for="paycheckNumber">Weekly paycheck contribution <input id="paycheckNumber" type="number" value={defaultInputs.paycheck} min="0" max="5000" step="0.01" /></label><input id="paycheck" type="range" aria-labelledby="paycheckLabel" value={defaultInputs.paycheck} min="0" max="5000" step="0.01" /></div>
            <div class="callout compact"><b>Paid bi-weekly?</b> Divide your paycheck contribution by 2 and enter that weekly amount here. Example: if you contribute $1,500 every two weeks, enter $750.</div>
            <div class="callout compact"><b>Pillar assumptions:</b> allocations must total 100%. Each yield applies only to that pillar's share. Anchor and Closed-end (A/C) distributions are reinvested; Booster and Dynamo (B/D) distributions remain spendable cash.</div>
            <div class="field"><label id="anchorAllocationLabel" for="anchorAllocationNumber">Anchor allocation % <input id="anchorAllocationNumber" type="number" value={defaultInputs.anchorAllocation} min="0" max="100" step="any" /></label><input id="anchorAllocation" type="range" aria-labelledby="anchorAllocationLabel" value={defaultInputs.anchorAllocation} min="0" max="100" step="any" /></div>
            <div class="field"><label id="anchorYieldLabel" for="anchorYieldNumber">Anchor annual yield % <input id="anchorYieldNumber" type="number" value={defaultInputs.anchorYield} min="0" max="80" step="0.1" /></label><input id="anchorYield" type="range" aria-labelledby="anchorYieldLabel" value={defaultInputs.anchorYield} min="0" max="80" step="0.1" /></div>
            <div class="field"><label id="boosterAllocationLabel" for="boosterAllocationNumber">Booster allocation % <input id="boosterAllocationNumber" type="number" value={defaultInputs.boosterAllocation} min="0" max="100" step="any" /></label><input id="boosterAllocation" type="range" aria-labelledby="boosterAllocationLabel" value={defaultInputs.boosterAllocation} min="0" max="100" step="any" /></div>
            <div class="field"><label id="boosterYieldLabel" for="boosterYieldNumber">Booster annual yield % <input id="boosterYieldNumber" type="number" value={defaultInputs.boosterYield} min="0" max="80" step="0.1" /></label><input id="boosterYield" type="range" aria-labelledby="boosterYieldLabel" value={defaultInputs.boosterYield} min="0" max="80" step="0.1" /></div>
            <div class="field"><label id="closedEndAllocationLabel" for="closedEndAllocationNumber">Closed-end allocation % <input id="closedEndAllocationNumber" type="number" value={defaultInputs.closedEndAllocation} min="0" max="100" step="any" /></label><input id="closedEndAllocation" type="range" aria-labelledby="closedEndAllocationLabel" value={defaultInputs.closedEndAllocation} min="0" max="100" step="any" /></div>
            <div class="field"><label id="closedEndYieldLabel" for="closedEndYieldNumber">Closed-end annual yield % <input id="closedEndYieldNumber" type="number" value={defaultInputs.closedEndYield} min="0" max="80" step="0.1" /></label><input id="closedEndYield" type="range" aria-labelledby="closedEndYieldLabel" value={defaultInputs.closedEndYield} min="0" max="80" step="0.1" /></div>
            <div class="field"><label id="dynamoAllocationLabel" for="dynamoAllocationNumber">Dynamo allocation % <input id="dynamoAllocationNumber" type="number" value={defaultInputs.dynamoAllocation} min="0" max="100" step="any" /></label><input id="dynamoAllocation" type="range" aria-labelledby="dynamoAllocationLabel" value={defaultInputs.dynamoAllocation} min="0" max="100" step="any" /></div>
            <div class="field"><label id="dynamoYieldLabel" for="dynamoYieldNumber">Dynamo annual yield % <input id="dynamoYieldNumber" type="number" value={defaultInputs.dynamoYield} min="0" max="80" step="0.1" /></label><input id="dynamoYield" type="range" aria-labelledby="dynamoYieldLabel" value={defaultInputs.dynamoYield} min="0" max="80" step="0.1" /></div>
            <div class="field"><label id="marketShockLabel" for="marketShockNumber">Immediate NAV/price shock % <input id="marketShockNumber" type="number" value={defaultInputs.marketShock} min="0" max="100" step="0.1" /></label><input id="marketShock" type="range" aria-labelledby="marketShockLabel" value={defaultInputs.marketShock} min="0" max="100" step="0.1" /></div>
            <div class="callout compact"><b>Market-shock assumption:</b> this synthetic one-time loss is applied to gross market value immediately. Margin debt does not fall with it.</div>
            <div class="field"><label id="distributionCutLabel" for="distributionCutNumber">Immediate distribution cut % <input id="distributionCutNumber" type="number" value={defaultInputs.distributionCut} min="0" max="100" step="0.1" /></label><input id="distributionCut" type="range" aria-labelledby="distributionCutLabel" value={defaultInputs.distributionCut} min="0" max="100" step="0.1" /></div>
            <div class="callout compact"><b>Distribution-cut assumption:</b> this immediate proportional cut reduces every pillar yield before ongoing annual dividend growth. It affects both reinvested A/C and spendable B/D distributions.</div>
            <p id="allocationStatus" class="footer-note" aria-live="polite">Pillar allocations total 100%.</p>
            <div class="field"><label id="growthLabel" for="growthNumber">Dividend growth % <input id="growthNumber" type="number" value={defaultInputs.dividendGrowth} min="-20" max="40" step="0.1" /></label><input id="growth" type="range" aria-labelledby="growthLabel" value={defaultInputs.dividendGrowth} min="-20" max="40" step="0.1" /></div>
            <div class="field"><label id="navReturnLabel" for="navReturnNumber">Annual NAV/price return % <input id="navReturnNumber" type="number" value={defaultInputs.annualNavReturn} min="-50" max="30" step="0.1" /></label><input id="navReturn" type="range" aria-labelledby="navReturnLabel" value={defaultInputs.annualNavReturn} min="-50" max="30" step="0.1" /></div>
            <div class="callout compact"><b>NAV/price assumption:</b> this compounds as a smooth user-selected estimate, not a forecast. It changes gross market value without being counted as a distribution.</div>
