        $('projectionExportStatus').textContent = '';
        ($('exportProjectionCsv') as HTMLButtonElement).disabled = false;
        $('grossMarketValue').textContent = fmt.format(marginAccount.grossMarketValue); $('cumulativeMarketShock').textContent = fmtSmall.format(last.cumulativeMarketShock); $('marginDebtResult').textContent = fmt.format(marginAccount.marginDebt); $('cumulativePrincipalPaid').textContent = fmtSmall.format(last.cumulativePrincipalPaid); $('pausedContributions').textContent = fmtSmall.format(last.pausedContributions); $('cumulativeMarginInterest').textContent = fmtSmall.format(last.cumulativeMarginInterest); $('netEquity').textContent = fmt.format(marginAccount.netEquity); $('marginEquityPercent').textContent = `${marginAccount.marginEquityPercent.toFixed(1)}%`; $('periodIncome').textContent = (last.periodIncome < 1000 ? fmtSmall : fmt).format(last.periodIncome) + '/' + periodLabel(); $('annualIncome').textContent = fmt.format(last.annualIncome); $('realIncome').textContent = fmt.format(last.annualIncome / Math.pow(1 + input.i, input.projectionYears)); $('grossDistributions').textContent = fmt.format(last.grossDistributions); $('reinvestedDistributions').textContent = fmt.format(last.reinvestedDistributions); $('spendableDistributions').textContent = fmt.format(last.spendableDistributions); $('expensesPaid').textContent = fmt.format(last.expensesPaid); $('uncoveredExpenses').textContent = fmt.format(last.uncoveredExpenses); $('remainingCash').textContent = fmt.format(last.remainingCash); $('expenseCrossover').textContent = expenseCrossoverText;
        const chart = $('chart'); chart.setAttribute('aria-label', 'Line plot of projected dividend income'); const svg = chart; const W = 900, H = 440, p = { l: 72, r: 26, t: 30, b: 56 }; const years = Array.from({ length: input.projectionYears }, (_, index) => index + 1); const points = years.map((year) => rows[Math.min(rows.length - 1, Math.round(year * periods))]); const incomeValue = (r: ProjectionRow) => r.annualIncome / periods; const realIncomeValue = (r: ProjectionRow) => (r.annualIncome / Math.pow(1 + input.i, r.year)) / periods; const expenseValue = (r: ProjectionRow) => r.inflationNeed / periods; const maxY = Math.max(...points.map(incomeValue), ...points.map(realIncomeValue), ...points.map(expenseValue)) * 1.12 || 1; const x = (r: ProjectionRow) => p.l + (input.projectionYears === 1 ? 0.5 : ((r.year - 1) / (input.projectionYears - 1))) * (W - p.l - p.r); const y = (value: number) => p.t + (1 - value / maxY) * (H - p.t - p.b); const pointPath = (valueFor: (row: ProjectionRow) => number) => points.map((r, idx) => `${idx ? 'L' : 'M'} ${x(r)} ${y(valueFor(r))}`).join(' ');
        let grid = `<rect x="${p.l}" y="${p.t}" width="${W-p.l-p.r}" height="${H-p.t-p.b}" rx="10" fill="rgba(255,253,247,.72)" stroke="rgba(32,63,105,.18)" stroke-width="1" />`;
        for (let i = 0; i <= 16; i++) { const gy = p.t + i * (H - p.t - p.b) / 16; grid += `<line x1="${p.l}" y1="${gy}" x2="${W-p.r}" y2="${gy}" stroke="rgba(32,63,105,.075)" stroke-width="1" />`; }
        if (input.projectionYears > 1) { for (let i = 0; i <= (input.projectionYears - 1) * 2; i++) { const gx = p.l + (i / ((input.projectionYears - 1) * 2)) * (W - p.l - p.r); grid += `<line x1="${gx}" y1="${p.t}" x2="${gx}" y2="${H-p.b}" stroke="rgba(32,63,105,.065)" stroke-width="1" />`; } }
        for (let i = 0; i <= 4; i++) { const value = (maxY * (4 - i)) / 4; const gy = p.t + i * (H - p.t - p.b) / 4; grid += `<line x1="${p.l}" y1="${gy}" x2="${W-p.r}" y2="${gy}" stroke="rgba(32,63,105,.15)" stroke-width="1" />`; grid += `<text x="${p.l - 10}" y="${gy + 4}" text-anchor="end" fill="#617086" font-size="12">${fmt.format(value)}</text>`; }
        years.forEach((year) => { const gx = p.l + (input.projectionYears === 1 ? 0.5 : ((year - 1) / (input.projectionYears - 1))) * (W - p.l - p.r); grid += `<line x1="${gx}" y1="${p.t}" x2="${gx}" y2="${H-p.b}" stroke="rgba(32,63,105,.15)" stroke-width="1" />`; grid += `<text x="${gx}" y="${H-20}" text-anchor="middle" fill="#617086" font-size="12">Y${year}</text>`; });
        const dots = points.map((r) => `<circle cx="${x(r)}" cy="${y(incomeValue(r))}" r="5" fill="#bf7327" stroke="#fffdf7" stroke-width="2"/><circle cx="${x(r)}" cy="${y(realIncomeValue(r))}" r="5" fill="#617f3e" stroke="#fffdf7" stroke-width="2"/><circle cx="${x(r)}" cy="${y(expenseValue(r))}" r="5" fill="#aa463d" stroke="#fffdf7" stroke-width="2"/>`).join('');
        svg.innerHTML = `${grid}<path d="${pointPath(incomeValue)}" fill="none" stroke="#bf7327" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/><path d="${pointPath(realIncomeValue)}" fill="none" stroke="#617f3e" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/><path d="${pointPath(expenseValue)}" fill="none" stroke="#aa463d" stroke-width="3" stroke-dasharray="8 8" stroke-linecap="round" stroke-linejoin="round"/>${dots}<line x1="${p.l}" y1="${H-p.b}" x2="${W-p.r}" y2="${H-p.b}" stroke="rgba(23,36,58,.16)" stroke-width="1"/><line x1="${p.l}" y1="${p.t}" x2="${p.l}" y2="${H-p.b}" stroke="rgba(23,36,58,.16)" stroke-width="1"/><text x="${p.l}" y="18" fill="#617086" font-size="12">Line plot: monthly dollars · weekly contributions</text><text x="${W-p.r}" y="18" text-anchor="end" fill="#617086" font-size="12">${input.projectionYears}-year projection</text>`;
      }
      function initializeSimulator() {
        const simulatorShell = document.getElementById('simulatorShell');
        const controlsToggle = document.getElementById('controlsToggle');
        if (!simulatorShell || !controlsToggle) {
          document.removeEventListener('keydown', closeSimulatorControls);
          return;
        }
        const transferredBudget = applyTransferredContribution();
        pairs.forEach(([a,b]) => sync(a,b));
        $('exportProjectionCsv').addEventListener('click', () => {
          const downloaded = downloadProjectionSummaryCsv(currentProjectionSummary);
          $('projectionExportStatus').textContent = downloaded
            ? 'Projection summary exported as CSV.'
            : 'Enter valid projection inputs before exporting.';
        });
        const snapshotBalanceInputs = {
          anchor: $('anchorBalance') as HTMLInputElement,
          booster: $('boosterBalance') as HTMLInputElement,
          closedEnd: $('closedEndBalance') as HTMLInputElement,
          dynamo: $('dynamoBalance') as HTMLInputElement,
        };
        const snapshotMarginDebtInput = $('snapshotMarginDebt') as HTMLInputElement;
        const currentSnapshot = () => readAllocationSnapshotInputs(
          snapshotBalanceInputs,
          snapshotMarginDebtInput,
        );
        const activeDynamoCount = $('activeDynamoCount') as HTMLInputElement;
        const dynamoCountStatus = $('dynamoCountStatus');
        const renderDynamoCount = () => {
          try {
            const result = calculateDynamoPositionCap(activeDynamoCount.valueAsNumber);
            activeDynamoCount.removeAttribute('aria-invalid');
            dynamoCountStatus.textContent = result.exceedsLimit
              ? `${result.activeCount} active Dynamos exceeds the ${result.limit}-position cap.`
              : `${result.activeCount} active Dynamos is within the ${result.limit}-position cap.`;
          } catch {
            activeDynamoCount.setAttribute('aria-invalid', 'true');
            dynamoCountStatus.textContent = 'Enter a whole number of active Dynamos, zero or greater.';
          }
        };
        activeDynamoCount.addEventListener('input', renderDynamoCount);
        renderDynamoCount();
        const anonymousUnderlyingGroups = $('anonymousUnderlyingGroups') as HTMLTextAreaElement;
        const duplicateUnderlyingStatus = $('duplicateUnderlyingStatus');
        const renderDuplicateUnderlyingExposure = () => {
          if (anonymousUnderlyingGroups.value.trim() === '') {
            anonymousUnderlyingGroups.removeAttribute('aria-invalid');
            duplicateUnderlyingStatus.textContent = 'Enter anonymous group tags to check duplicate underlying exposure.';
            return;
          }
          try {
            const result = calculateDuplicateUnderlyingExposure(anonymousUnderlyingGroups.value);
            anonymousUnderlyingGroups.removeAttribute('aria-invalid');
            duplicateUnderlyingStatus.textContent = result.hasDuplicateExposure
              ? `${result.duplicateGroupCount} duplicate underlying group affects ${result.duplicatePositionCount} of ${result.positionCount} positions.`
              : `No duplicate underlying groups across ${result.positionCount} positions.`;
          } catch {
            anonymousUnderlyingGroups.setAttribute('aria-invalid', 'true');
            duplicateUnderlyingStatus.textContent = 'Enter one synthetic tag per line, starting with group-, using up to 32 letters, numbers, or hyphen-separated parts.';
          }
        };
        anonymousUnderlyingGroups.addEventListener('input', renderDuplicateUnderlyingExposure);
        const anonymousPositionValues = $('anonymousPositionValues') as HTMLTextAreaElement;
        const positionConcentrationStatus = $('positionConcentrationStatus');
        const renderPositionConcentration = () => {
          if (anonymousPositionValues.value.trim() === '') {
            anonymousPositionValues.removeAttribute('aria-invalid');
            positionConcentrationStatus.textContent = 'Enter anonymous position values to check the 5% and 7% concentration limits.';
            return;
          }
          try {
            const positionValues = parseAnonymousPositionValues(anonymousPositionValues.value);
            const portfolioValue = calculatePillarAllocationSnapshot({
              anchor: snapshotBalanceInputs.anchor.valueAsNumber,
              booster: snapshotBalanceInputs.booster.valueAsNumber,
              closedEnd: snapshotBalanceInputs.closedEnd.valueAsNumber,
              dynamo: snapshotBalanceInputs.dynamo.valueAsNumber,
            }).totalValue;
            const concentration = calculatePositionConcentration({ portfolioValue, positionValues });
            anonymousPositionValues.removeAttribute('aria-invalid');
            positionConcentrationStatus.textContent = `Across ${concentration.positionCount} anonymous positions, the largest is ${concentration.largestPositionPercent.toFixed(2)}%. ${concentration.aboveFivePercentCount} above 5% attention threshold; ${concentration.aboveSevenPercentCount} above 7% hard limit.`;
          } catch {
            anonymousPositionValues.setAttribute('aria-invalid', 'true');
            positionConcentrationStatus.textContent = 'Enter one valid non-negative market value per line. Each value and their combined total must not exceed the current gross allocation total.';
          }
        };
        anonymousPositionValues.addEventListener('input', renderPositionConcentration);
        Object.values(snapshotBalanceInputs).forEach((input) => {
          input.addEventListener('input', renderPositionConcentration);
        });
        const allocationSnapshotController = attachAllocationSnapshot({
          balanceInputs: snapshotBalanceInputs,
          marginDebtInput: snapshotMarginDebtInput,
          applyButton: $('applyAllocationSnapshot') as HTMLButtonElement,
          summary: $('allocationSnapshotSummary'),
          allocationControls: {
            anchor: [$('anchorAllocation'), $('anchorAllocationNumber')],
            booster: [$('boosterAllocation'), $('boosterAllocationNumber')],
            closedEnd: [$('closedEndAllocation'), $('closedEndAllocationNumber')],
            dynamo: [$('dynamoAllocation'), $('dynamoAllocationNumber')],
          },
          startingControls: [$('starting'), $('startingNumber')],
          startingMarginControls: [$('marginDebt'), $('marginDebtNumber')],
          calculateSnapshot: calculatePillarMarginSnapshot,
          prepareProjectionSnapshot: preparePillarMarginSnapshotForProjection,
          maxStartingValue: Number($('starting').max),
          formatCurrency: (value: number) => fmtSmall.format(value),
          render: () => {
            document.querySelectorAll('[data-scenario]').forEach((button) => button.setAttribute('aria-pressed', 'false'));
            render();
          },
        });
        attachAllocationSnapshotStorage({
          balanceInputs: snapshotBalanceInputs,
          marginDebtInput: snapshotMarginDebtInput,
          saveButton: $('saveAllocationSnapshot') as HTMLButtonElement,
          resetButton: $('resetAllocationSnapshot') as HTMLButtonElement,
          status: $('allocationSnapshotStorageStatus'),
          storage: getAllocationSnapshotStorage(window),
          restoreSnapshot: restoreAllocationSnapshot,
          saveSnapshot: saveAllocationSnapshot,
          clearSnapshot: clearAllocationSnapshot,
          refreshSummary: () => {
            allocationSnapshotController.refreshSummary();
            renderPositionConcentration();
          },
        });
        const snapshotStatus = $('allocationSnapshotStorageStatus');
        const snapshotFile = $('allocationSnapshotFile') as HTMLInputElement;
        $('exportAllocationSnapshot').addEventListener('click', () => {
          const serialized = serializeAllocationSnapshotExport(
            currentSnapshot(),
            new Date().toISOString(),
          );
          if (!serialized) {
            snapshotStatus.textContent = 'Enter a valid aggregate snapshot before exporting.';
            return;
          }
          const downloadUrl = URL.createObjectURL(new Blob([serialized], { type: 'application/json' }));
          const link = document.createElement('a');
          link.href = downloadUrl;
          link.download = 'abcds-allocation-snapshot.json';
          link.click();
          URL.revokeObjectURL(downloadUrl);
          snapshotStatus.textContent = 'Aggregate allocation snapshot exported as JSON.';
        });
        $('exportAllocationSnapshotCsv').addEventListener('click', () => {
          const downloaded = downloadAllocationSnapshotCsv(
            currentSnapshot(),
            new Date().toISOString(),
          );
          snapshotStatus.textContent = downloaded
            ? 'Aggregate allocation snapshot exported as CSV.'
            : 'Enter a valid aggregate snapshot before exporting.';
        });
        const snapshotImports = createAllocationSnapshotImportCoordinator();
        $('importAllocationSnapshot').addEventListener('click', () => {
          snapshotImports.openFilePicker(snapshotFile);
        });
        snapshotFile.addEventListener('change', async () => {
          const request = snapshotImports.begin();
          const file = snapshotFile.files?.[0];
          if (!file) return;
          try {
            const importResult = await readAllocationSnapshotImportFile(file);
            if (!request.isCurrent()) return;
            if (importResult.status === 'too-large') {
              snapshotStatus.textContent = 'Could not import that aggregate snapshot JSON because the file is too large. Current inputs were not changed.';
              return;
            }
            if (importResult.status !== 'loaded') throw new Error('Invalid allocation snapshot export');
            const { imported } = importResult;
            for (const [name, input] of Object.entries(snapshotBalanceInputs)) {
              input.value = String(imported.snapshot[name]);
              input.removeAttribute('aria-invalid');
            }
            snapshotMarginDebtInput.value = String(imported.snapshot.marginDebt);
            snapshotMarginDebtInput.removeAttribute('aria-invalid');
            allocationSnapshotController.refreshSummary();
            renderPositionConcentration();
            snapshotStatus.textContent = 'Imported aggregate snapshot from JSON. Choose Save in browser to persist it.';
          } catch {
            if (request.isCurrent()) {
              snapshotStatus.textContent = 'Could not import that aggregate snapshot JSON. Current inputs were not changed.';
            }
          } finally {
            if (request.isCurrent()) snapshotFile.value = '';
          }
        });
        attachProjectionScenarioPresets({
          buttons: [...document.querySelectorAll('[data-scenario]')],
          controls: {
            anchorAllocation: [$('anchorAllocation'), $('anchorAllocationNumber')],
            anchorYield: [$('anchorYield'), $('anchorYieldNumber')],
            boosterAllocation: [$('boosterAllocation'), $('boosterAllocationNumber')],
            boosterYield: [$('boosterYield'), $('boosterYieldNumber')],
            closedEndAllocation: [$('closedEndAllocation'), $('closedEndAllocationNumber')],
            closedEndYield: [$('closedEndYield'), $('closedEndYieldNumber')],
            dynamoAllocation: [$('dynamoAllocation'), $('dynamoAllocationNumber')],
            dynamoYield: [$('dynamoYield'), $('dynamoYieldNumber')],
            marketShock: [$('marketShock'), $('marketShockNumber')],
            distributionCut: [$('distributionCut'), $('distributionCutNumber')],
            dividendGrowth: [$('growth'), $('growthNumber')],
            annualNavReturn: [$('navReturn'), $('navReturnNumber')],
            inflation: [$('inflation'), $('inflationNumber')],
          },
          resultsStatus: $('resultsStatus'),
          getScenario: getProjectionScenario,
          isValid: () => !hasInvalidInputs(),
          invalidateResults,
          render,
        });
        const simulatorControls = $('simulatorControls');
        attachSimulatorControlsToggle({
          simulatorShell,
          controlsToggle,
          simulatorControls,
          matchMedia: window.matchMedia.bind(window),
          requestFrame: requestAnimationFrame,
        });
        document.removeEventListener('keydown', closeSimulatorControls);
        document.addEventListener('keydown', closeSimulatorControls);
        render();
        if (transferredBudget.contribution !== null || transferredBudget.marginRepair !== null) {
          const contributionMessage = transferredBudget.contribution === null
            ? ''
            : `Weekly contribution imported from budget: ${fmtSmall.format(transferredBudget.contribution)}. `;
          const repairMessage = transferredBudget.marginRepair === null
            ? ''
            : `Weekly margin repair imported from budget: ${fmtSmall.format(transferredBudget.marginRepair)}. `;
          $('resultsStatus').textContent = `${contributionMessage}${repairMessage}Projection updated.`;
        }
      }
      document.addEventListener('astro:page-load', initializeSimulator);
    </script>
    <Analytics />
  </body>
