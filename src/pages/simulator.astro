---
import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';
import RadialSiteMenu from '../components/RadialSiteMenu.astro';
import SkipLink from '../components/SkipLink.astro';
import SiteFooter from '../components/SiteFooter.astro';

const defaultInputs = {
  starting: 60450,
  marginDebt: 0,
  paycheck: 750,
  dividendYield: 22,
  acDistributionShare: 50,
  dividendGrowth: 4,
  inflation: 7,
  monthlyExpenses: 2600,
  projectionYears: 5,
};


---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ABCD Income Projection Lab</title>
    <ClientRouter />
    <style>
      :root { --bg:#f6f0e4; --paper:#fffdf7; --paper-2:#fbf6ea; --ink:#17243a; --muted:#617086; --line:rgba(23,36,58,.15); --a:#203f69; --b:#bf7327; --c:#617f3e; --d:#aa463d; --gold:#c79a2c; --shadow:0 28px 90px rgba(42,31,13,.15); --serif:Georgia,'Times New Roman',serif; --sans:ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; --mono:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace; }
      * { box-sizing:border-box; }
      html { scroll-behavior:smooth; }
      body { margin:0; font-family:var(--sans); color:var(--ink); background:radial-gradient(circle at 10% 5%, rgba(199,154,44,.22), transparent 27rem), radial-gradient(circle at 88% 13%, rgba(32,63,105,.16), transparent 26rem), radial-gradient(circle at 75% 90%, rgba(97,127,62,.14), transparent 24rem), linear-gradient(90deg, rgba(23,36,58,.035) 1px, transparent 1px), linear-gradient(rgba(23,36,58,.035) 1px, transparent 1px), var(--bg); background-size:auto, auto, auto, 30px 30px, 30px 30px, auto; }
      a { color:inherit; }
      .shell { width:min(1440px, calc(100vw - 28px)); margin:0 auto; padding:22px 0 64px; }
      .topbar { display:flex; justify-content:space-between; gap:12px; align-items:center; margin-bottom:14px; }
      .pill { border:1px solid var(--line); border-radius:999px; padding:9px 12px; background:rgba(255,255,255,.55); text-decoration:none; color:var(--a); font-weight:850; font-size:13px; }
      .donate-link { display:inline-flex; align-items:center; gap:9px; min-height:42px; border:1px solid color-mix(in srgb, var(--b) 42%, transparent); border-radius:999px; padding:0 15px; background:color-mix(in srgb, var(--b) 12%, var(--paper)); color:var(--a); text-decoration:none; font-weight:950; box-shadow:0 12px 28px rgba(42,31,13,.1); }
      .donate-link::before { content:'$'; display:grid; place-items:center; width:26px; height:26px; border-radius:999px; background:var(--b); color:var(--paper); font:950 14px var(--mono); }
      .donate-link:hover { transform:translateY(-1px); box-shadow:0 16px 34px rgba(42,31,13,.14); }
      .hero, .panel { border:1px solid var(--line); border-radius:34px; background:rgba(255,253,247,.91); box-shadow:var(--shadow); overflow:hidden; }
      .hero { padding:clamp(28px, 5vw, 58px); margin-bottom:28px; position:relative; }
      .hero::before { content:""; position:absolute; inset:22px; border:1px dashed rgba(32,63,105,.18); border-radius:26px; pointer-events:none; }
      .eyebrow { font:850 12px var(--mono); letter-spacing:.14em; text-transform:uppercase; color:var(--d); }
      h1 { margin:12px 0 18px; font:950 clamp(46px, 8vw, 96px)/.88 var(--serif); letter-spacing:-.06em; color:var(--a); max-width:12ch; }
      h2 { margin:0; font:950 clamp(30px, 5vw, 62px)/.92 var(--serif); letter-spacing:-.045em; color:var(--a); }
      p { color:#49576c; line-height:1.58; }
      .lead { font-size:clamp(18px, 2vw, 24px); max-width:860px; }
      .hero-actions { display:flex; gap:10px; flex-wrap:wrap; margin-top:24px; }
      .button { display:inline-flex; align-items:center; justify-content:center; min-height:44px; border-radius:999px; padding:0 16px; text-decoration:none; font-weight:900; border:1px solid var(--line); cursor:pointer; }
      .button.primary { background:var(--a); color:var(--paper); border-color:var(--a); }
      .button.secondary { background:rgba(255,255,255,.6); color:var(--a); }
      .panel { padding:clamp(24px, 4vw, 48px); }
      .section-head { display:flex; align-items:end; justify-content:space-between; gap:16px; margin-bottom:24px; }
      .sim { position:relative; display:block; }
      .controls-toggle { display:inline-flex; align-items:center; justify-content:center; gap:10px; min-height:54px; margin-bottom:14px; border:2px solid rgba(255,253,247,.9); border-radius:999px; padding:0 22px; background:linear-gradient(135deg, var(--a), #315f99); color:var(--paper); font-weight:950; font-size:16px; cursor:pointer; box-shadow:0 16px 38px rgba(32,63,105,.28), 0 0 0 5px rgba(32,63,105,.10); animation:pulseHint 2.4s ease-in-out infinite; }
      .controls-toggle::before { content:'☰'; font-size:18px; }
      @keyframes pulseHint { 0%,100% { transform:translateY(0); box-shadow:0 16px 38px rgba(32,63,105,.28), 0 0 0 5px rgba(32,63,105,.10); } 50% { transform:translateY(-1px); box-shadow:0 20px 44px rgba(32,63,105,.34), 0 0 0 8px rgba(191,115,39,.14); } }
      .controls { position:absolute; left:16px; top:58px; z-index:10; width:min(390px, calc(100% - 32px)); max-height:min(680px, calc(100vh - 120px)); overflow:auto; border:1px solid var(--line); border-radius:26px; padding:18px; background:rgba(251,246,234,.96); backdrop-filter:blur(18px); box-shadow:0 26px 80px rgba(42,31,13,.22); opacity:0; pointer-events:none; transform:translateY(-8px) scale(.98); transition:opacity .18s ease, transform .18s ease; }
      .sim.controls-open .controls { opacity:1; pointer-events:auto; transform:translateY(0) scale(1); }
      .field { display:grid; gap:7px; margin-bottom:14px; }
      .field label { display:flex; align-items:center; justify-content:space-between; gap:12px; font-weight:850; color:var(--a); }
      .field input[type='range'] { width:100%; accent-color:var(--a); }
      .field input[type='number'] { width:130px; border:1px solid var(--line); border-radius:12px; padding:8px 10px; background:var(--paper); color:var(--ink); font:800 14px var(--mono); }
      .scenario-presets { margin-bottom:18px; border:0; padding:0; }
      .scenario-presets legend { margin-bottom:8px; font-weight:900; color:var(--a); }
      .scenario-buttons { display:flex; flex-wrap:wrap; gap:8px; }
      .scenario-button { min-height:40px; border:1px solid var(--line); border-radius:999px; padding:0 13px; background:var(--paper); color:var(--a); font-weight:850; cursor:pointer; }
      .scenario-button[aria-pressed='true'] { border-color:var(--a); background:var(--a); color:var(--paper); }
      .chart-wrap { border:1px solid var(--line); border-radius:26px; background:linear-gradient(180deg, rgba(32,63,105,.05), rgba(255,253,247,.7)); padding:18px; min-height:560px; }
      .stats { display:grid; grid-template-columns:repeat(auto-fit, minmax(180px,1fr)); gap:10px; margin-bottom:14px; }
      .stat { border:1px solid var(--line); border-radius:18px; padding:12px; background:rgba(255,255,255,.62); }
      .stat strong { display:block; font:950 26px var(--serif); color:var(--a); }
      .sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border:0; }
      svg { width:100%; height:auto; display:block; }
      .legend { display:flex; gap:10px; flex-wrap:wrap; margin-top:12px; color:var(--muted); font-size:13px; }
      .legend span { display:inline-flex; align-items:center; gap:7px; }
      .swatch { width:18px; height:4px; border-radius:999px; display:inline-block; }
      .callout { border-left:6px solid var(--gold); border-radius:18px; padding:16px 18px; background:rgba(199,154,44,.13); }
      .compact { min-height:auto; }
      .footer-note { margin-top:16px; color:var(--muted); font-size:13px; }
      @media (max-width: 900px) { .stats { grid-template-columns:1fr; } .section-head, .topbar { align-items:flex-start; flex-direction:column; } }
      @media (prefers-reduced-motion: reduce) { html { scroll-behavior:auto; } }
    </style>
  </head>
  <body>
    <SkipLink />
    <div class="shell">
      <div class="topbar"><a class="pill" href="/">← Back to main guide</a><a class="donate-link" href="https://cash.app/$knosence" target="_blank" rel="noopener noreferrer">Donate $knosence</a></div>

      <main id="main-content" tabindex="-1">
      <header class="hero" transition:name="hero">
        <div class="eyebrow">Projection lab</div>
        <h1>Run the income path projection.</h1>
        <p class="lead">Test contribution pace, yield assumptions, dividend growth, inflation, and expense targets without scrolling through the full guide.</p>
        <p class="footer-note"><b>Menu lab:</b> need to place items manually? Open the <a href="/menu-lab">menu layout lab</a>.</p>
        <div class="hero-actions"><a class="button primary" href="#simulator">Open inputs</a><a class="button secondary" href="/getting-started">Start from zero</a><a class="button secondary" href="/budget">Budget first</a><a class="button secondary" href="/#gears">Choose a gear</a></div>
      </header>

      <section id="simulator" class="panel" transition:name="simulator-panel">
        <div class="section-head"><h2>Income path simulator</h2><span class="pill">start here: open inputs</span></div>
        <div class="sim" id="simulatorShell">
          <button class="controls-toggle" id="controlsToggle" type="button" aria-expanded="false" aria-controls="simulatorControls">Open simulator inputs</button>
          <aside class="controls" id="simulatorControls">
            <fieldset class="scenario-presets">
              <legend>Starting assumptions</legend>
              <div class="scenario-buttons">
                <button class="scenario-button" type="button" data-scenario="conservative" aria-pressed="false">Conservative</button>
                <button class="scenario-button" type="button" data-scenario="base" aria-pressed="false">Base</button>
                <button class="scenario-button" type="button" data-scenario="stress" aria-pressed="false">Stress</button>
              </div>
              <p class="footer-note">These presets fill only the income assumptions below as transparent starting points. The stress preset applies a synthetic distribution-cut path; NAV/price decline, margin interest and principal repayment remain outside this bounded model.</p>
            </fieldset>
            <div class="field"><label id="startingLabel" for="startingNumber">Starting gross market value <input id="startingNumber" type="number" value={defaultInputs.starting} min="0" step="500" /></label><input id="starting" type="range" aria-labelledby="startingLabel" value={defaultInputs.starting} min="0" max="250000" step="500" /></div>
            <div class="field"><label id="marginDebtLabel" for="marginDebtNumber">Starting margin debt <input id="marginDebtNumber" type="number" value={defaultInputs.marginDebt} min="0" max={defaultInputs.starting} step="100" /></label><input id="marginDebt" type="range" aria-labelledby="marginDebtLabel" value={defaultInputs.marginDebt} min="0" max={defaultInputs.starting} step="100" /></div>
            <div class="field"><label id="paycheckLabel" for="paycheckNumber">Weekly paycheck contribution <input id="paycheckNumber" type="number" value={defaultInputs.paycheck} min="0" max="5000" step="0.01" /></label><input id="paycheck" type="range" aria-labelledby="paycheckLabel" value={defaultInputs.paycheck} min="0" max="5000" step="0.01" /></div>
            <div class="callout compact"><b>Paid bi-weekly?</b> Divide your paycheck contribution by 2 and enter that weekly amount here. Example: if you contribute $1,500 every two weeks, enter $750.</div>
            <div class="field"><label id="yieldLabel" for="yieldNumber">Portfolio dividend % <input id="yieldNumber" type="number" value={defaultInputs.dividendYield} min="0" max="80" step="0.1" /></label><input id="yield" type="range" aria-labelledby="yieldLabel" value={defaultInputs.dividendYield} min="0" max="80" step="0.1" /></div>
            <div class="field"><label id="acShareLabel" for="acShareNumber">A/C distribution share (DRIP on) <input id="acShareNumber" type="number" value={defaultInputs.acDistributionShare} min="0" max="100" step="1" /></label><input id="acShare" type="range" aria-labelledby="acShareLabel" value={defaultInputs.acDistributionShare} min="0" max="100" step="1" /></div>
            <div class="callout compact"><b>Distribution routing:</b> Anchor and Closed-end (A/C) distributions are reinvested into market value. Booster and Dynamo (B/D) distributions remain spendable cash.</div>
            <div class="field"><label id="growthLabel" for="growthNumber">Dividend growth % <input id="growthNumber" type="number" value={defaultInputs.dividendGrowth} min="-20" max="40" step="0.1" /></label><input id="growth" type="range" aria-labelledby="growthLabel" value={defaultInputs.dividendGrowth} min="-20" max="40" step="0.1" /></div>
            <div class="field"><label id="inflationLabel" for="inflationNumber">Inflation % <input id="inflationNumber" type="number" value={defaultInputs.inflation} min="0" max="20" step="0.1" /></label><input id="inflation" type="range" aria-labelledby="inflationLabel" value={defaultInputs.inflation} min="0" max="20" step="0.1" /></div>
            <div class="field"><label id="expensesLabel" for="expensesNumber">Monthly expenses <input id="expensesNumber" type="number" value={defaultInputs.monthlyExpenses} min="0" step="50" /></label><input id="expenses" type="range" aria-labelledby="expensesLabel" value={defaultInputs.monthlyExpenses} min="0" max="15000" step="50" /></div>
            <div class="field"><label id="projectionYearsLabel" for="projectionYearsNumber">Projection years <input id="projectionYearsNumber" type="number" value={defaultInputs.projectionYears} min="1" max="30" step="1" /></label><input id="projectionYears" type="range" aria-labelledby="projectionYearsLabel" value={defaultInputs.projectionYears} min="1" max="30" step="1" /></div>
            <p class="footer-note"><b>Beginner version:</b> enter what you have now, what you can add each week, your expected dividend yield, your monthly bills, and how many years you want to project. If you do not yet know what weekly contribution is realistic, use the companion <a href="/budget">budget guide</a> first.</p>
          </aside>
          <div class="chart-wrap">
            <div class="stats">
              <div class="stat"><span>Ending gross market value</span><strong id="grossMarketValue">—</strong></div>
              <div class="stat"><span>Margin debt</span><strong id="marginDebtResult">—</strong></div>
              <div class="stat"><span>Ending net equity</span><strong id="netEquity">—</strong></div>
              <div class="stat"><span>Margin equity</span><strong id="marginEquityPercent">—</strong></div>
              <div class="stat"><span>Monthly income</span><strong id="periodIncome">—</strong></div>
              <div class="stat"><span>Annual income</span><strong id="annualIncome">—</strong></div>
              <div class="stat"><span>Inflation-adjusted</span><strong id="realIncome">—</strong></div>
              <div class="stat"><span>Gross distributions</span><strong id="grossDistributions">—</strong></div>
              <div class="stat"><span>Reinvested A/C distributions</span><strong id="reinvestedDistributions">—</strong></div>
              <div class="stat"><span>Spendable B/D distributions</span><strong id="spendableDistributions">—</strong></div>
            </div>
            <p id="resultsStatus" class="sr-only" role="status" aria-live="polite" aria-atomic="true"></p>
            <p class="footer-note" style="margin-top:0">Distribution ledgers are cumulative for the projection. Gross market value includes external contributions and reinvested A/C distributions, but excludes spendable B/D cash. Margin principal is held constant in this bounded model; interest and principal repayment are not modeled yet.</p>
            <p class="footer-note" style="margin-top:0"><b>How to read it:</b> orange = projected monthly dividends, green = today-dollar buying power, red = expenses after inflation.</p>
            <svg id="chart" viewBox="0 0 900 440" role="img" aria-label="Line plot of projected dividend income"></svg>
            <div class="legend"><span><i class="swatch" style="background:var(--b)"></i>Nominal dividend income</span><span><i class="swatch" style="background:var(--c)"></i>Inflation-adjusted income</span><span><i class="swatch" style="background:var(--d)"></i>Inflated expense target</span></div>
          </div>
        </div>
      </section>
      </main>
      <SiteFooter />
    </div>

    <RadialSiteMenu page="simulator" />

    <script>
      import { calculateMarginAccount, getProjectionScenario, parseWeeklyContribution, routePillarDistributions } from '../lib/financial-calculations.mjs';
      import { attachProjectionScenarioPresets, attachSimulatorControlsToggle } from '../lib/simulator-controls.mjs';

      const $ = (id) => document.getElementById(id);
      const pairs = [['starting', 'startingNumber'], ['marginDebt', 'marginDebtNumber'], ['paycheck', 'paycheckNumber'], ['yield', 'yieldNumber'], ['acShare', 'acShareNumber'], ['growth', 'growthNumber'], ['inflation', 'inflationNumber'], ['expenses', 'expensesNumber'], ['projectionYears', 'projectionYearsNumber']];
      const fmt = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
      const fmtSmall = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 2 });
      let marginDebtAdjustmentAnnouncement = '';
      function hasInvalidInputs() {
        return pairs.some(([, numberId]) => $(numberId).getAttribute('aria-invalid') === 'true');
      }
      function invalidateResults() {
        const resultIds = ['grossMarketValue', 'marginDebtResult', 'netEquity', 'marginEquityPercent', 'periodIncome', 'annualIncome', 'realIncome', 'grossDistributions', 'reinvestedDistributions', 'spendableDistributions'];
        resultIds.forEach((id) => { $(id).textContent = '—'; });
        const chart = $('chart');
        chart.replaceChildren();
        chart.setAttribute('aria-label', 'Projection unavailable while an input is invalid');
      }
      function announceResultsIfValid() {
        const resultsStatus = $('resultsStatus');
        if (hasInvalidInputs()) {
          resultsStatus.textContent = 'Enter a value within the allowed range.';
          return;
        }
        announceResults();
      }
      function sync(a, b) {
        const range = $(a);
        const number = $(b);
        const resultsStatus = $('resultsStatus');
        range.addEventListener('input', () => {
          number.value = range.value;
          number.removeAttribute('aria-invalid');
          if (hasInvalidInputs()) {
            resultsStatus.textContent = 'Enter a value within the allowed range.';
            return;
          }
          resultsStatus.textContent = '';
          render();
        });
        number.addEventListener('input', () => {
          if (
            number.value.trim() === ''
            || !number.validity.valid
            || !Number.isFinite(number.valueAsNumber)
          ) {
            number.setAttribute('aria-invalid', 'true');
            invalidateResults();
            resultsStatus.textContent = 'Enter a value within the allowed range.';
            return;
          }
          const enteredValue = number.valueAsNumber;
          range.value = String(enteredValue);
          number.value = range.value;
          number.removeAttribute('aria-invalid');
          if (hasInvalidInputs()) {
            resultsStatus.textContent = 'Enter a value within the allowed range.';
            return;
          }
          resultsStatus.textContent = '';
          render();
        });
        range.addEventListener('change', announceResultsIfValid);
        number.addEventListener('change', announceResultsIfValid);
      }
      function closeSimulatorControls(event) {
        if (event.key !== 'Escape') return;
        const simulatorShell = $('simulatorShell');
        const controlsToggle = $('controlsToggle');
        if (!simulatorShell || !controlsToggle) return;
        simulatorShell.classList.remove('controls-open');
        controlsToggle.setAttribute('aria-expanded', 'false');
        controlsToggle.textContent = 'Open simulator inputs';
      }
      function constrainMarginDebt() {
        const starting = $('starting');
        const marginDebt = $('marginDebt');
        const marginDebtNumber = $('marginDebtNumber');
        const currentDebt = Number(marginDebt.value);
        marginDebt.max = starting.value;
        marginDebtNumber.max = starting.value;
        const boundedDebt = Math.min(currentDebt, Number(starting.value));
        marginDebt.value = String(boundedDebt);
        marginDebtNumber.value = marginDebt.value;
        marginDebtNumber.removeAttribute('aria-invalid');
        marginDebtAdjustmentAnnouncement = currentDebt !== boundedDebt
          ? 'Margin debt was adjusted because it cannot exceed starting gross market value.'
          : '';
      }
      function getInputs() { return { starting: Number($('starting').value), marginDebt: Number($('marginDebt').value), paycheck: Number($('paycheck').value), y: Number($('yield').value) / 100, acShare: Number($('acShare').value) / 100, g: Number($('growth').value) / 100, i: Number($('inflation').value) / 100, monthlyExpenses: Number($('expenses').value), projectionYears: Math.max(1, Math.round(Number($('projectionYears').value))) }; }
      function periodCount() { return 12; }
      function periodLabel() { return 'month'; }
      function announceResults() {
        const adjustmentMessage = marginDebtAdjustmentAnnouncement ? `${marginDebtAdjustmentAnnouncement} ` : '';
        $('resultsStatus').textContent = `${adjustmentMessage}Projection updated. Gross market value ${$('grossMarketValue').textContent}. Margin debt ${$('marginDebtResult').textContent}. Net equity ${$('netEquity').textContent}. Margin equity ${$('marginEquityPercent').textContent}. Monthly income ${$('periodIncome').textContent}. Spendable B/D distributions ${$('spendableDistributions').textContent}.`;
      }
      function applyTransferredContribution() {
        const searchParams = new URLSearchParams(window.location.hash.slice(1));
        const requestedContribution = searchParams.get('weeklyContribution');
        const requestedNumber = Number(requestedContribution);
        const transferredContribution = parseWeeklyContribution(
          requestedContribution,
          { fallback: 750, max: 5000 },
        );
        const paycheck = $('paycheck');
        const paycheckNumber = $('paycheckNumber');
        paycheck.value = transferredContribution;
        const appliedContribution = Number(paycheck.value);
        paycheckNumber.value = appliedContribution;
        return requestedContribution !== null
          && requestedContribution.trim() !== ''
          && Number.isFinite(requestedNumber)
          ? appliedContribution
          : null;
      }
      function simulate() { const input = getInputs(); const periods = periodCount(); const totalPeriods = periods * input.projectionYears; const contribution = (input.paycheck * 52) / periods; let portfolio = input.starting; let grossDistributions = 0; let reinvestedDistributions = 0; let spendableDistributions = 0; const rows = []; for (let t = 0; t <= totalPeriods; t++) { const year = t / periods; const currentYield = Math.max(0, input.y * Math.pow(1 + input.g, year)); const annualIncome = portfolio * currentYield; const periodIncome = annualIncome / periods; const inflationNeed = input.monthlyExpenses * 12 * Math.pow(1 + input.i, year); rows.push({ t, year, portfolio, annualIncome, periodIncome, inflationNeed, grossDistributions, reinvestedDistributions, spendableDistributions }); const acDistribution = periodIncome * input.acShare; const bdDistribution = periodIncome - acDistribution; const routed = routePillarDistributions({ marketValue: portfolio, anchor: acDistribution / 2, booster: bdDistribution / 2, closedEnd: acDistribution / 2, dynamo: bdDistribution / 2 }); grossDistributions += routed.grossDistributions; reinvestedDistributions += routed.reinvestedDistributions; spendableDistributions += routed.spendableDistributions; portfolio = routed.endingMarketValue + contribution; } return rows; }
      function render() {
        constrainMarginDebt();
        const rows = simulate(); const last = rows[rows.length - 1]; const input = getInputs(); const periods = periodCount();
        const marginAccount = calculateMarginAccount({ marketValue: last.portfolio, marginDebt: input.marginDebt });
        $('grossMarketValue').textContent = fmt.format(marginAccount.grossMarketValue); $('marginDebtResult').textContent = fmt.format(marginAccount.marginDebt); $('netEquity').textContent = fmt.format(marginAccount.netEquity); $('marginEquityPercent').textContent = `${marginAccount.marginEquityPercent.toFixed(1)}%`; $('periodIncome').textContent = (last.periodIncome < 1000 ? fmtSmall : fmt).format(last.periodIncome) + '/' + periodLabel(); $('annualIncome').textContent = fmt.format(last.annualIncome); $('realIncome').textContent = fmt.format(last.annualIncome / Math.pow(1 + input.i, input.projectionYears)); $('grossDistributions').textContent = fmt.format(last.grossDistributions); $('reinvestedDistributions').textContent = fmt.format(last.reinvestedDistributions); $('spendableDistributions').textContent = fmt.format(last.spendableDistributions);
        const chart = $('chart'); chart.setAttribute('aria-label', 'Line plot of projected dividend income'); const svg = chart; const W = 900, H = 440, p = { l: 72, r: 26, t: 30, b: 56 }; const years = Array.from({ length: input.projectionYears }, (_, index) => index + 1); const points = years.map((year) => rows[Math.min(rows.length - 1, Math.round(year * periods))]); const incomeValue = (r) => r.annualIncome / periods; const realIncomeValue = (r) => (r.annualIncome / Math.pow(1 + input.i, r.year)) / periods; const expenseValue = (r) => r.inflationNeed / periods; const maxY = Math.max(...points.map(incomeValue), ...points.map(realIncomeValue), ...points.map(expenseValue)) * 1.12 || 1; const x = (r) => p.l + (input.projectionYears === 1 ? 0.5 : ((r.year - 1) / (input.projectionYears - 1))) * (W - p.l - p.r); const y = (value) => p.t + (1 - value / maxY) * (H - p.t - p.b); const pointPath = (valueFor) => points.map((r, idx) => `${idx ? 'L' : 'M'} ${x(r)} ${y(valueFor(r))}`).join(' ');
        let grid = `<rect x="${p.l}" y="${p.t}" width="${W-p.l-p.r}" height="${H-p.t-p.b}" rx="10" fill="rgba(255,253,247,.72)" stroke="rgba(32,63,105,.18)" stroke-width="1" />`;
        for (let i = 0; i <= 16; i++) { const gy = p.t + i * (H - p.t - p.b) / 16; grid += `<line x1="${p.l}" y1="${gy}" x2="${W-p.r}" y2="${gy}" stroke="rgba(32,63,105,.075)" stroke-width="1" />`; }
        if (input.projectionYears > 1) { for (let i = 0; i <= (input.projectionYears - 1) * 2; i++) { const gx = p.l + (i / ((input.projectionYears - 1) * 2)) * (W - p.l - p.r); grid += `<line x1="${gx}" y1="${p.t}" x2="${gx}" y2="${H-p.b}" stroke="rgba(32,63,105,.065)" stroke-width="1" />`; } }
        for (let i = 0; i <= 4; i++) { const value = (maxY * (4 - i)) / 4; const gy = p.t + i * (H - p.t - p.b) / 4; grid += `<line x1="${p.l}" y1="${gy}" x2="${W-p.r}" y2="${gy}" stroke="rgba(32,63,105,.15)" stroke-width="1" />`; grid += `<text x="${p.l - 10}" y="${gy + 4}" text-anchor="end" fill="#617086" font-size="12">${fmt.format(value)}</text>`; }
        years.forEach((year) => { const gx = p.l + (input.projectionYears === 1 ? 0.5 : ((year - 1) / (input.projectionYears - 1))) * (W - p.l - p.r); grid += `<line x1="${gx}" y1="${p.t}" x2="${gx}" y2="${H-p.b}" stroke="rgba(32,63,105,.15)" stroke-width="1" />`; grid += `<text x="${gx}" y="${H-20}" text-anchor="middle" fill="#617086" font-size="12">Y${year}</text>`; });
        const dots = points.map((r) => `<circle cx="${x(r)}" cy="${y(incomeValue(r))}" r="5" fill="#bf7327" stroke="#fffdf7" stroke-width="2"/><circle cx="${x(r)}" cy="${y(realIncomeValue(r))}" r="5" fill="#617f3e" stroke="#fffdf7" stroke-width="2"/><circle cx="${x(r)}" cy="${y(expenseValue(r))}" r="5" fill="#aa463d" stroke="#fffdf7" stroke-width="2"/>`).join('');
        svg.innerHTML = `${grid}<path d="${pointPath(incomeValue)}" fill="none" stroke="#bf7327" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/><path d="${pointPath(realIncomeValue)}" fill="none" stroke="#617f3e" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/><path d="${pointPath(expenseValue)}" fill="none" stroke="#aa463d" stroke-width="3" stroke-dasharray="8 8" stroke-linecap="round" stroke-linejoin="round"/>${dots}<line x1="${p.l}" y1="${H-p.b}" x2="${W-p.r}" y2="${H-p.b}" stroke="rgba(23,36,58,.16)" stroke-width="1"/><line x1="${p.l}" y1="${p.t}" x2="${p.l}" y2="${H-p.b}" stroke="rgba(23,36,58,.16)" stroke-width="1"/><text x="${p.l}" y="18" fill="#617086" font-size="12">Line plot: monthly dollars · weekly contributions</text><text x="${W-p.r}" y="18" text-anchor="end" fill="#617086" font-size="12">${input.projectionYears}-year projection</text>`;
      }
      function initializeSimulator() {
        const simulatorShell = $('simulatorShell');
        const controlsToggle = $('controlsToggle');
        if (!simulatorShell || !controlsToggle) {
          document.removeEventListener('keydown', closeSimulatorControls);
          return;
        }
        const transferredContribution = applyTransferredContribution();
        pairs.forEach(([a,b]) => sync(a,b));
        attachProjectionScenarioPresets({
          buttons: [...document.querySelectorAll('[data-scenario]')],
          controls: {
            dividendYield: [$('yield'), $('yieldNumber')],
            acDistributionShare: [$('acShare'), $('acShareNumber')],
            dividendGrowth: [$('growth'), $('growthNumber')],
            inflation: [$('inflation'), $('inflationNumber')],
          },
          resultsStatus: $('resultsStatus'),
          getScenario: getProjectionScenario,
          isValid: () => !hasInvalidInputs(),
          invalidateResults,
          render,
        });
        const simulatorControls = $('simulatorControls');
        attachSimulatorControlsToggle({
          simulatorShell,
          controlsToggle,
          simulatorControls,
          matchMedia: window.matchMedia.bind(window),
          requestFrame: requestAnimationFrame,
        });
        document.removeEventListener('keydown', closeSimulatorControls);
        document.addEventListener('keydown', closeSimulatorControls);
        render();
        if (transferredContribution !== null) {
          $('resultsStatus').textContent = `Weekly contribution imported from budget: ${fmtSmall.format(transferredContribution)}. Projection updated.`;
        }
      }
      document.addEventListener('astro:page-load', initializeSimulator);
    </script>
    <Analytics />
  </body>
</html>
