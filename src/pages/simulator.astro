      function getInputs() { return { starting: Number($('starting').value), marginDebt: Number($('marginDebt').value), marginApr: Number($('marginApr').value), weeklyMarginRepair: Number($('weeklyMarginRepair').value), paycheck: Number($('paycheck').value), pillars: { anchor: { allocation: Number($('anchorAllocation').value), annualYield: Number($('anchorYield').value) }, booster: { allocation: Number($('boosterAllocation').value), annualYield: Number($('boosterYield').value) }, closedEnd: { allocation: Number($('closedEndAllocation').value), annualYield: Number($('closedEndYield').value) }, dynamo: { allocation: Number($('dynamoAllocation').value), annualYield: Number($('dynamoYield').value) } }, marketShock: Number($('marketShock').value), distributionCut: Number($('distributionCut').value), g: Number($('growth').value) / 100, navReturn: Number($('navReturn').value), i: Number($('inflation').value) / 100, monthlyExpenses: Number($('expenses').value), projectionYears: Math.max(1, Math.round(Number($('projectionYears').value))) }; }
